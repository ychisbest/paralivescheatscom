---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Props {
  title: string;
  description?: string;
  fullTitle?: string;
  canonicalPath?: string;
  schema?: Record<string, any>[];
  ogType?: string;
}

const {
  title,
  description = 'The most complete collection of Paralives cheats for the 2026 Early Access. Browse all Paralives cheat codes for money, needs, skills, careers, and more. Click to copy and use instantly.',
  fullTitle,
  canonicalPath,
  schema,
  ogType = 'website',
} = Astro.props;

const pageTitle = fullTitle || `${title} | Paralives Cheats`;
const canonicalUrl = canonicalPath
  ? `https://paralives-cheats.com${canonicalPath}`
  : `https://paralives-cheats.com${Astro.url.pathname}`;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Paralives Cheats" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {schema && schema.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
    <script type="text/javascript">
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "wxfam7570q");
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-[#FCFCFD] text-gray-900 antialiased">
    <SiteHeader />
    <main class="flex-1">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
