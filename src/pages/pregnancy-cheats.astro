---
import Layout from '../layouts/Layout.astro';
import CheatTable from '../components/CheatTable.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const cheats = [
  { code: 'getpregnant [1-3]', desc: 'Make the selected Para pregnant. Optionally specify multiples. Example: getpregnant 2' },
  { code: 'givebirth', desc: 'Make the selected pregnant Para give birth immediately.' },
  { code: 'makebabies', desc: 'Make two selected Paras have a baby together.' },
  { code: 'pregnantstatus', desc: 'Show pregnancy progress and status.' },
];

const faqs = [
  { q: 'How do I get pregnant in Paralives?', a: 'Select the Para you want to make pregnant, open the console (Ctrl + F1), and type "getpregnant". Add a number 1-3 for multiples, like "getpregnant 2" for twins.' },
  { q: 'How do I give birth immediately?', a: 'Use the "givebirth" cheat to make the selected pregnant Para give birth instantly. Make sure the Para is actually pregnant first — use "pregnantstatus" to check.' },
  { q: 'Can I make two Paras have a baby together?', a: 'Yes! Select both Paras and use the "makebabies" cheat. This will create a baby from the two selected Paras.' },
  { q: 'How do I check pregnancy progress?', a: 'Use "pregnantstatus" to see the current pregnancy progress and status of the selected Para.' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": { "@type": "Answer", "text": faq.a }
  }))
};

const relatedPages = [
  { title: 'Money Cheats', href: '/money-cheats', desc: 'Get unlimited Paradimes' },
  { title: 'Needs Cheats', href: '/needs-cheats', desc: 'Fill all needs instantly' },
  { title: 'Aging Cheats', href: '/#aging', desc: 'Control life stages' },
  { title: 'All Cheats', href: '/#cheats', desc: 'Browse all 76+ cheats' },
];
---

<Layout
  title="Pregnancy Cheats"
  fullTitle="Paralives Pregnancy Cheats 2026 - Get Pregnant & Give Birth | Paralives Cheats"
  description="All Paralives pregnancy cheats: getpregnant, givebirth, makebabies, pregnantstatus. Control pregnancy and babies with these tested cheat codes."
  canonicalPath="/pregnancy-cheats"
  schema={[faqSchema]}
>
  <Breadcrumb items={[
    { name: 'Home', href: '/' },
    { name: 'Pregnancy Cheats' }
  ]} />

  <header class="max-w-7xl mx-auto px-6 py-16 md:py-24 text-center">
    <p class="text-sm font-bold text-gray-400 mb-4 uppercase tracking-wider">Updated: June 2026</p>
    <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight leading-[1.1] mb-6">
      Paralives <span class="bg-[#f472b6] text-white px-3 py-1 border border-black inline-block rotate-[-1deg]">Pregnancy Cheats</span>
    </h1>
    <p class="text-xl text-gray-700 max-w-2xl mx-auto leading-relaxed font-medium mb-6">
      Control pregnancy and babies in Paralives with these cheat codes. Get pregnant instantly, have twins or triplets, and give birth on demand.
    </p>
    <p class="text-lg text-gray-500 font-bold">
      Press <span class="bg-[#FFD54F] px-2 border-2 border-black">Ctrl + F1</span> to open the console, then type any code below.
    </p>
  </header>

  <section class="py-16 bg-white border-y-[3px] border-black">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl font-extrabold mb-2">All Pregnancy Cheat Codes</h2>
      <p class="text-gray-600 font-medium mb-8">Click any code to copy it to your clipboard, then paste into the console.</p>
      <CheatTable cheats={cheats} color="bg-[#f472b6]" />

      <div class="mt-12 bg-[#FCE7F3] border border-black rounded-3xl p-8 brutal-shadow">
        <h3 class="text-2xl font-extrabold mb-4">👶 Pregnancy Cheat Tips</h3>
        <ul class="space-y-3 text-gray-800 font-medium">
          <li class="flex items-start gap-3">
            <span class="text-xl">🤰</span>
            <span>Select the Para you want to make pregnant before typing <code class="bg-black text-white px-2 py-0.5 rounded-full text-sm font-bold">getpregnant</code>.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-xl">👯</span>
            <span>For twins, use <code class="bg-black text-white px-2 py-0.5 rounded-full text-sm font-bold">getpregnant 2</code>. For triplets, use <code class="bg-black text-white px-2 py-0.5 rounded-full text-sm font-bold">getpregnant 3</code>.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-xl">👶</span>
            <span>Use <code class="bg-black text-white px-2 py-0.5 rounded-full text-sm font-bold">makebabies</code> to have two selected Paras create a baby together.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-xl">📋</span>
            <span>Check pregnancy progress anytime with <code class="bg-black text-white px-2 py-0.5 rounded-full text-sm font-bold">pregnantstatus</code>.</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section class="py-16 bg-[#F9FAFB] border-b-[3px] border-black">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl font-extrabold mb-8 text-center">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqs.map(faq => (
          <div class="border border-black rounded-2xl p-6 bg-white brutal-shadow">
            <h3 class="text-xl font-extrabold mb-2">{faq.q}</h3>
            <p class="text-gray-700 font-medium text-lg">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-[#E0F2FE] border-b-[3px] border-black">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl font-extrabold mb-8 text-center">Related Paralives Cheats</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {relatedPages.map(page => (
          <a href={page.href} class="bg-white border border-black rounded-2xl p-6 brutal-shadow hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all block">
            <h3 class="font-extrabold text-lg mb-1">{page.title}</h3>
            <p class="text-gray-600 font-medium">{page.desc}</p>
            <span class="font-bold text-[#6366f1] underline underline-offset-4 decoration-2 text-sm">View Cheats →</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const code = btn.getAttribute('data-code');
      if (!code) return;
      try {
        await navigator.clipboard.writeText(code);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = code;
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
      }
      const copyIcon = btn.querySelector('.copy-icon');
      const checkIcon = btn.querySelector('.check-icon');
      copyIcon.classList.add('hidden');
      checkIcon.classList.remove('hidden');
      setTimeout(() => {
        copyIcon.classList.remove('hidden');
        checkIcon.classList.add('hidden');
      }, 1500);
    });
  });
</script>
