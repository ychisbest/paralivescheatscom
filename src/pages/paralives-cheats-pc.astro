---
import Layout from '../layouts/Layout.astro';
import CheatTable from '../components/CheatTable.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const topCheats = [
  { code: 'JACKPOT', desc: 'Add 50,000 Paradimes instantly.' },
  { code: 'reliefallneeds', desc: 'Fill all needs for the selected Para.' },
  { code: 'setskilllevel Cooking 10', desc: 'Max out the Cooking skill.' },
  { code: 'setmoney 50000', desc: 'Set exact money amount.' },
  { code: 'advanceday', desc: 'Skip 24 hours ahead.' },
  { code: 'unstuck', desc: 'Fix a stuck Para.' },
  { code: 'editcharacter', desc: 'Reopen character creator.' },
  { code: 'save', desc: 'Save the current game.' },
  { code: 'zipsavefile', desc: 'Create a save backup.' },
  { code: 'help', desc: 'Show all commands.' },
];

const faqs = [
  { q: 'How do I use cheats in Paralives on PC?', a: 'Press Ctrl + F1 or Ctrl + Shift + C to open the cheat console on PC. Type any cheat code and press Enter. Codes are not case-sensitive.' },
  { q: 'Are Paralives cheats available on PC only?', a: 'Paralives is currently only available on PC (Steam Early Access, 2026). All cheats work on the PC version through the built-in console.' },
  { q: 'What are the best PC cheats for Paralives?', a: 'The best PC cheats are: JACKPOT (money), reliefallneeds (fill needs), setskilllevel (max skills), and unstuck (fix bugs). See the full list below.' },
  { q: 'Do Paralives cheats work on Steam Deck?', a: 'Paralives cheats should work on Steam Deck, but you may need to map the console shortcut (Ctrl + F1) to a button combination.' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": { "@type": "Answer", "text": faq.a }
  }))
};

const relatedPages = [
  { title: 'All Cheats', href: '/#cheats', desc: 'Browse all 76+ cheats' },
  { title: 'Console Commands', href: '/console-commands', desc: 'How to use the console' },
  { title: 'Cheat Codes', href: '/cheat-codes', desc: 'Quick reference table' },
  { title: 'WeMod Trainer', href: '/wemod-trainer', desc: 'WeMod alternatives' },
];
---

<Layout
  title="Paralives Cheats PC"
  fullTitle="Paralives Cheats PC 2026 - All PC Cheat Codes | Paralives Cheats"
  description="All Paralives cheats for PC. How to open the console, enter cheat codes, and use all 76+ cheats on the PC version of Paralives (Steam Early Access 2026)."
  canonicalPath="/paralives-cheats-pc"
  schema={[faqSchema]}
>
  <Breadcrumb items={[
    { name: 'Home', href: '/' },
    { name: 'Paralives Cheats PC' }
  ]} />

  <header class="max-w-7xl mx-auto px-6 py-16 md:py-24 text-center">
    <p class="text-sm font-bold text-gray-400 mb-4 uppercase tracking-wider">Updated: June 2026</p>
    <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight leading-[1.1] mb-6">
      Paralives <span class="bg-[#6366f1] text-white px-3 py-1 border border-black inline-block rotate-[-1deg]">Cheats PC</span>
    </h1>
    <p class="text-xl text-gray-700 max-w-2xl mx-auto leading-relaxed font-medium mb-6">
      All Paralives cheats for the PC version. Learn how to open the console on PC and use every cheat code available in the 2026 Steam Early Access.
    </p>
    <p class="text-lg text-gray-500 font-bold">
      Press <span class="bg-[#FFD54F] px-2 border-2 border-black">Ctrl + F1</span> or <span class="bg-[#FFD54F] px-2 border-2 border-black">Ctrl + Shift + C</span> on PC to open the console.
    </p>
  </header>

  <section class="py-16 bg-white border-y-[3px] border-black">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl font-extrabold mb-2">Top 10 PC Cheats</h2>
      <p class="text-gray-600 font-medium mb-8">The most useful cheats for PC players. Click any code to copy it.</p>
      <CheatTable cheats={topCheats} color="bg-[#6366f1]" />

      <div class="mt-12 bg-[#E0F2FE] border border-black rounded-3xl p-8 brutal-shadow">
        <h3 class="text-2xl font-extrabold mb-4">🖥️ PC-Specific Tips</h3>
        <ul class="space-y-3 text-gray-800 font-medium">
          <li class="flex items-start gap-3">
            <span class="text-xl">⌨️</span>
            <span><strong>Keyboard shortcut:</strong> <code class="bg-black text-white px-2 py-0.5 rounded-full text-sm font-bold">Ctrl + F1</code> or <code class="bg-black text-white px-2 py-0.5 rounded-full text-sm font-bold">Ctrl + Shift + C</code> opens the console.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-xl">🎮</span>
            <span><strong>Steam Deck:</strong> Map the console shortcut to a button combination in Steam Input settings.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-xl">📋</span>
            <span><strong>Copy-paste:</strong> Click any cheat code on this page to copy it, then Ctrl+V in the console.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-xl">💾</span>
            <span><strong>Save location:</strong> Use <code class="bg-black text-white px-2 py-0.5 rounded-full text-sm font-bold">zipsavefile</code> to backup saves (reportedly saved to your desktop).</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section class="py-16 bg-[#F9FAFB] border-b-[3px] border-black">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl font-extrabold mb-8 text-center">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqs.map(faq => (
          <div class="border border-black rounded-2xl p-6 bg-white brutal-shadow">
            <h3 class="text-xl font-extrabold mb-2">{faq.q}</h3>
            <p class="text-gray-700 font-medium text-lg">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-[#E0F2FE] border-b-[3px] border-black">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl font-extrabold mb-8 text-center">Related Paralives Cheats</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {relatedPages.map(page => (
          <a href={page.href} class="bg-white border border-black rounded-2xl p-6 brutal-shadow hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all block">
            <h3 class="font-extrabold text-lg mb-1">{page.title}</h3>
            <p class="text-gray-600 font-medium">{page.desc}</p>
            <span class="font-bold text-[#6366f1] underline underline-offset-4 decoration-2 text-sm">View Cheats →</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const code = btn.getAttribute('data-code');
      if (!code) return;
      try {
        await navigator.clipboard.writeText(code);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = code;
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
      }
      const copyIcon = btn.querySelector('.copy-icon');
      const checkIcon = btn.querySelector('.check-icon');
      copyIcon.classList.add('hidden');
      checkIcon.classList.remove('hidden');
      setTimeout(() => {
        copyIcon.classList.remove('hidden');
        checkIcon.classList.add('hidden');
      }, 1500);
    });
  });
</script>
