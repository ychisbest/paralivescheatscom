---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const cheats = [
  { code: 'JACKPOT', desc: 'Aggiungi 50.000 Paradimi al fondo famiglia.' },
  { code: 'MAKEITRAIN', desc: 'Aggiungi 10.000 Paradimi.' },
  { code: 'PIGGYBANK', desc: 'Aggiungi 1.000 Paradimi.' },
  { code: 'setmoney [importo]', desc: 'Imposta un importo esatto. Esempio: setmoney 500000' },
  { code: 'reliefallneeds', desc: 'Riempi immediatamente tutti i bisogni del Para selezionato.' },
  { code: 'setskilllevel [abilità] [livello]', desc: 'Imposta il livello di un\'abilità. Esempio: setskilllevel Cooking 10' },
  { code: 'getpregnant [1-3]', desc: 'Rendi incinta il Para selezionato.' },
  { code: 'givebirth', desc: 'Parto istantaneo.' },
  { code: 'editcharacter', desc: 'Riapri il creatore di personaggi.' },
  { code: 'unstuck', desc: 'Correggi un Para bloccato.' },
  { code: 'save', desc: 'Salva il gioco.' },
  { code: 'help', desc: 'Mostra tutti i comandi disponibili.' },
];

const faqs = [
  { q: 'Come aprire la console dei trucchi in Paralives?', a: 'Premi Ctrl + F1 o Ctrl + Shift + C su Windows. Su Mac, prova Ctrl + Fn + F1. Poi digita qualsiasi codice trucco.' },
  { q: 'I trucchi di Paralives sono sensibili alle maiuscole?', a: 'No. I trucchi di Paralives non sono sensibili alle maiuscole. Puoi scrivere "JACKPOT" o "jackpot" — funzionano entrambi.' },
  { q: 'Come aggiungere soldi in Paralives?', a: 'Usa il codice "JACKPOT" per aggiungere 50.000 Paradimi, "MAKEITRAIN" per 10.000, o "setmoney [importo]" per impostare un importo esatto.' },
  { q: 'Come riempire tutti i bisogni?', a: 'Digita "reliefallneeds" per riempire immediatamente tutti i bisogni del Para selezionato.' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": { "@type": "Answer", "text": faq.a }
  }))
};
---

<Layout
  title="Paralives Trucchi"
  fullTitle="Paralives Trucchi 2026 - Tutti i Codici Cheat | Paralives Cheats"
  description="Tutti i trucchi di Paralives: soldi, bisogni, abilità, gravidanza e altro. Clicca per copiare e incollare nella console."
  canonicalPath="/paralives-trucchi"
  schema={[faqSchema]}
  lang="it"
>
  <Breadcrumb items={[
    { name: 'Home', href: '/' },
    { name: 'Paralives Trucchi' }
  ]} />

  <header class="max-w-7xl mx-auto px-6 py-16 md:py-24 text-center">
    <p class="text-sm font-bold text-gray-400 mb-4 uppercase tracking-wider">Aggiornato: Giugno 2026</p>
    <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight leading-[1.1] mb-6">
      <span class="bg-[#6366f1] text-white px-3 py-1 border border-black inline-block rotate-[-1deg]">Paralives Trucchi</span> e Codici
    </h1>
    <p class="text-xl text-gray-700 max-w-2xl mx-auto leading-relaxed font-medium mb-6">
      La raccolta completa dei trucchi di Paralives per il 2026. Clicca qualsiasi codice per copiarlo e incollarlo nella console.
    </p>
    <p class="text-lg text-gray-500 font-bold">
      Premi <span class="bg-[#FFD54F] px-2 border-2 border-black">Ctrl + F1</span> per aprire la console.
    </p>
  </header>

  <section class="py-16 bg-white border-y-[3px] border-black">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl font-extrabold mb-8">Trucchi Popolari</h2>
      <div class="space-y-3">
        {cheats.map(cheat => (
          <div class="flex items-center justify-between gap-4 bg-[#F9FAFB] border border-black rounded-2xl p-4 md:p-5 brutal-shadow">
            <div class="flex-1 min-w-0">
              <code class="bg-[#6366f1] text-white px-3 py-1 rounded-full text-sm font-bold border border-black">{cheat.code}</code>
              <span class="ml-3 text-gray-700 font-medium">{cheat.desc}</span>
            </div>
          </div>
        ))}
      </div>
      <div class="mt-8 text-center">
        <a href="/#cheats" class="brutal-btn bg-[#6366f1] text-white font-extrabold text-lg py-3 px-8 rounded-full border border-black brutal-shadow inline-flex items-center gap-2">
          Vedi Tutti i Trucchi →
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 bg-[#F9FAFB] border-b-[3px] border-black">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl font-extrabold mb-8 text-center">Domande Frequenti</h2>
      <div class="space-y-4">
        {faqs.map(faq => (
          <div class="border border-black rounded-2xl p-6 bg-white brutal-shadow">
            <h3 class="text-xl font-extrabold mb-2">{faq.q}</h3>
            <p class="text-gray-700 font-medium text-lg">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-[#E0F2FE] border-b-[3px] border-black">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-extrabold mb-4">Altri Paralives Cheats</h2>
      <p class="text-gray-600 font-medium text-lg mb-8">Cerca più codici? Visita la nostra pagina principale con tutti i trucchi.</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="/money-cheats" class="bg-white border border-black rounded-2xl p-6 brutal-shadow hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all block">
          <h3 class="font-extrabold text-lg mb-1">Money Cheats</h3>
          <p class="text-gray-600 font-medium">Trucchi per i soldi</p>
        </a>
        <a href="/needs-cheats" class="bg-white border border-black rounded-2xl p-6 brutal-shadow hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all block">
          <h3 class="font-extrabold text-lg mb-1">Needs Cheats</h3>
          <p class="text-gray-600 font-medium">Trucchi per i bisogni</p>
        </a>
        <a href="/cheat-codes" class="bg-white border border-black rounded-2xl p-6 brutal-shadow hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all block">
          <h3 class="font-extrabold text-lg mb-1">All Cheat Codes</h3>
          <p class="text-gray-600 font-medium">Tutti i codici</p>
        </a>
      </div>
    </div>
  </section>
</Layout>
