---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Cookie Policy">
  <section class="max-w-4xl mx-auto px-6 py-20">
    <h1 class="text-5xl font-extrabold tracking-tight mb-8">Cookie Policy</h1>
    <div class="space-y-6">
      <p class="font-bold text-gray-500">Last updated: May 2026</p>

      <div class="bg-white border-[3px] border-black rounded-2xl p-6 brutal-shadow">
        <h2 class="text-2xl font-extrabold mb-3">What Are Cookies</h2>
        <p class="text-gray-700 font-medium text-lg">Cookies are small text files stored on your device when you visit a website. They help us provide you with a better experience.</p>
      </div>

      <div class="bg-white border-[3px] border-black rounded-2xl p-6 brutal-shadow">
        <h2 class="text-2xl font-extrabold mb-3">How We Use Cookies</h2>
        <ul class="space-y-2 text-gray-700 font-medium text-lg list-disc pl-6">
          <li>Essential website functionality</li>
          <li>Analytics to understand how visitors use our site</li>
          <li>Advertising to serve relevant ads</li>
          <li>Remembering your preferences</li>
        </ul>
      </div>

      <div class="bg-white border-[3px] border-black rounded-2xl p-6 brutal-shadow">
        <h2 class="text-2xl font-extrabold mb-3">Types of Cookies</h2>
        <ul class="space-y-2 text-gray-700 font-medium text-lg list-disc pl-6">
          <li><strong>Session cookies:</strong> Temporary cookies that expire when you close your browser</li>
          <li><strong>Persistent cookies:</strong> Remain on your device until they expire or you delete them</li>
          <li><strong>Third-party cookies:</strong> Set by our analytics and advertising partners</li>
        </ul>
      </div>

      <div class="bg-white border-[3px] border-black rounded-2xl p-6 brutal-shadow">
        <h2 class="text-2xl font-extrabold mb-3">Managing Cookies</h2>
        <p class="text-gray-700 font-medium text-lg">You can control cookies through your browser settings. Note that disabling cookies may affect website functionality.</p>
      </div>

      <div class="bg-white border-[3px] border-black rounded-2xl p-6 brutal-shadow">
        <h2 class="text-2xl font-extrabold mb-3">Third-Party Cookies</h2>
        <p class="text-gray-700 font-medium text-lg">We use Google Analytics and Google AdSense, which may set their own cookies. Please refer to their respective privacy policies for more information.</p>
      </div>
    </div>
  </section>
</Layout>
