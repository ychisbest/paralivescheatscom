---
import Layout from '../layouts/Layout.astro';

const moneyCheats = [
  { code: 'money.add [amount]', desc: 'Add money to your household. Example: money.add 10000' },
  { code: 'money.set [amount]', desc: 'Set household money to an exact amount.' },
  { code: 'money.infinite', desc: 'Enable infinite money mode for your household.' },
  { code: 'money.remove [amount]', desc: 'Remove a specific amount from household funds.' },
];

const buildingCheats = [
  { code: 'build.freerealestate', desc: 'Place objects anywhere without grid restrictions.' },
  { code: 'build.ignoreobjects', desc: 'Place objects overlapping other objects.' },
  { code: 'build.unlockall', desc: 'Unlock all build mode items including locked content.' },
  { code: 'build.moveobjects', desc: 'Move and place objects freely without restrictions.' },
  { code: 'build.resize [scale]', desc: 'Resize objects to any scale. Example: build.resize 2' },
  { code: 'build.showhidden', desc: 'Show hidden debug objects in build mode.' },
];

const skillCheats = [
  { code: 'skill.max [skill]', desc: 'Max out a specific skill. Example: skill.max cooking' },
  { code: 'skill.set [skill] [level]', desc: 'Set a skill to a specific level.' },
  { code: 'skill.unlockall', desc: 'Unlock all skills at maximum level.' },
  { code: 'skill.reset [skill]', desc: 'Reset a skill back to level 0.' },
];

const relationshipCheats = [
  { code: 'rel.add [name] [amount]', desc: 'Add relationship points with a character.' },
  { code: 'rel.set [name] [amount]', desc: 'Set relationship to a specific value.' },
  { code: 'rel.max [name]', desc: 'Max out relationship with a character.' },
  { code: 'rel.break [name]', desc: 'Break relationship with a character.' },
  { code: 'rel.makefriend [name]', desc: 'Instantly become best friends.' },
  { code: 'rel.makeromantic [name]', desc: 'Instantly become romantic partners.' },
];

const needsCheats = [
  { code: 'needs.fill', desc: 'Fill all needs for the current Para.' },
  { code: 'needs.fillall', desc: 'Fill all needs for all household members.' },
  { code: 'needs.disable', desc: 'Freeze all needs so they never decrease.' },
  { code: 'needs.enable', desc: 'Re-enable need decay after disabling.' },
  { code: 'needs.set [need] [value]', desc: 'Set a specific need to a value (0-100).' },
];

const ageCheats = [
  { code: 'age.set [stage]', desc: 'Set Para to a specific age stage (baby, child, teen, adult, elder).' },
  { code: 'age.up', desc: 'Age up the current Para by one stage.' },
  { code: 'age.down', desc: 'Age down the current Para by one stage.' },
  { code: 'age.freeze', desc: 'Prevent the current Para from aging.' },
];
---

<Layout title="All Paralives Cheats">
  <section class="max-w-6xl mx-auto px-4 py-16">
    <h1 class="text-4xl font-bold text-center mb-4">All Paralives Cheats</h1>
    <p class="text-center text-[#94a3b8] mb-12 max-w-2xl mx-auto">
      Complete list of all known Paralives cheat codes. Press <kbd class="bg-[#334155] px-2 py-1 rounded text-sm">Ctrl + Shift + C</kbd> (or <kbd class="bg-[#334155] px-2 py-1 rounded text-sm">Cmd + Shift + C</kbd> on Mac) to open the cheat console.
    </p>

    <div class="space-y-16">
      <!-- Money Cheats -->
      <div id="money">
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-3">
          <span class="text-3xl">💰</span> Money Cheats
        </h2>
        <div class="bg-[#1e293b] border border-[#334155] rounded-xl overflow-hidden">
          <table class="w-full">
            <thead>
              <tr class="border-b border-[#334155]">
                <th class="text-left px-6 py-3 text-sm font-semibold text-[#94a3b8]">Code</th>
                <th class="text-left px-6 py-3 text-sm font-semibold text-[#94a3b8]">Description</th>
              </tr>
            </thead>
            <tbody>
              {moneyCheats.map(cheat => (
                <tr class="border-b border-[#334155] last:border-0">
                  <td class="px-6 py-4"><code class="bg-[#334155] px-2 py-1 rounded text-sm text-[#6366f1]">{cheat.code}</code></td>
                  <td class="px-6 py-4 text-[#94a3b8]">{cheat.desc}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Building Cheats -->
      <div id="building">
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-3">
          <span class="text-3xl">🏗️</span> Building Cheats
        </h2>
        <div class="bg-[#1e293b] border border-[#334155] rounded-xl overflow-hidden">
          <table class="w-full">
            <thead>
              <tr class="border-b border-[#334155]">
                <th class="text-left px-6 py-3 text-sm font-semibold text-[#94a3b8]">Code</th>
                <th class="text-left px-6 py-3 text-sm font-semibold text-[#94a3b8]">Description</th>
              </tr>
            </thead>
            <tbody>
              {buildingCheats.map(cheat => (
                <tr class="border-b border-[#334155] last:border-0">
                  <td class="px-6 py-4"><code class="bg-[#334155] px-2 py-1 rounded text-sm text-[#6366f1]">{cheat.code}</code></td>
                  <td class="px-6 py-4 text-[#94a3b8]">{cheat.desc}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Skill Cheats -->
      <div id="skills">
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-3">
          <span class="text-3xl">⭐</span> Skill Cheats
        </h2>
        <div class="bg-[#1e293b] border border-[#334155] rounded-xl overflow-hidden">
          <table class="w-full">
            <thead>
              <tr class="border-b border-[#334155]">
                <th class="text-left px-6 py-3 text-sm font-semibold text-[#94a3b8]">Code</th>
                <th class="text-left px-6 py-3 text-sm font-semibold text-[#94a3b8]">Description</th>
              </tr>
            </thead>
            <tbody>
              {skillCheats.map(cheat => (
                <tr class="border-b border-[#334155] last:border-0">
                  <td class="px-6 py-4"><code class="bg-[#334155] px-2 py-1 rounded text-sm text-[#6366f1]">{cheat.code}</code></td>
                  <td class="px-6 py-4 text-[#94a3b8]">{cheat.desc}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Relationship Cheats -->
      <div id="relationships">
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-3">
          <span class="text-3xl">💕</span> Relationship Cheats
        </h2>
        <div class="bg-[#1e293b] border border-[#334155] rounded-xl overflow-hidden">
          <table class="w-full">
            <thead>
              <tr class="border-b border-[#334155]">
                <th class="text-left px-6 py-3 text-sm font-semibold text-[#94a3b8]">Code</th>
                <th class="text-left px-6 py-3 text-sm font-semibold text-[#94a3b8]">Description</th>
              </tr>
            </thead>
            <tbody>
              {relationshipCheats.map(cheat => (
                <tr class="border-b border-[#334155] last:border-0">
                  <td class="px-6 py-4"><code class="bg-[#334155] px-2 py-1 rounded text-sm text-[#6366f1]">{cheat.code}</code></td>
                  <td class="px-6 py-4 text-[#94a3b8]">{cheat.desc}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Needs Cheats -->
      <div id="needs">
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-3">
          <span class="text-3xl">🔋</span> Needs Cheats
        </h2>
        <div class="bg-[#1e293b] border border-[#334155] rounded-xl overflow-hidden">
          <table class="w-full">
            <thead>
              <tr class="border-b border-[#334155]">
                <th class="text-left px-6 py-3 text-sm font-semibold text-[#94a3b8]">Code</th>
                <th class="text-left px-6 py-3 text-sm font-semibold text-[#94a3b8]">Description</th>
              </tr>
            </thead>
            <tbody>
              {needsCheats.map(cheat => (
                <tr class="border-b border-[#334155] last:border-0">
                  <td class="px-6 py-4"><code class="bg-[#334155] px-2 py-1 rounded text-sm text-[#6366f1]">{cheat.code}</code></td>
                  <td class="px-6 py-4 text-[#94a3b8]">{cheat.desc}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Age Cheats -->
      <div id="age">
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-3">
          <span class="text-3xl">🎂</span> Age Cheats
        </h2>
        <div class="bg-[#1e293b] border border-[#334155] rounded-xl overflow-hidden">
          <table class="w-full">
            <thead>
              <tr class="border-b border-[#334155]">
                <th class="text-left px-6 py-3 text-sm font-semibold text-[#94a3b8]">Code</th>
                <th class="text-left px-6 py-3 text-sm font-semibold text-[#94a3b8]">Description</th>
              </tr>
            </thead>
            <tbody>
              {ageCheats.map(cheat => (
                <tr class="border-b border-[#334155] last:border-0">
                  <td class="px-6 py-4"><code class="bg-[#334155] px-2 py-1 rounded text-sm text-[#6366f1]">{cheat.code}</code></td>
                  <td class="px-6 py-4 text-[#94a3b8]">{cheat.desc}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>
</Layout>
