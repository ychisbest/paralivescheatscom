---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const cheats = [
  { code: 'JACKPOT', desc: 'Dodaj 50 000 Paradimów do funduszy gospodarstwa domowego.' },
  { code: 'MAKEITRAIN', desc: 'Dodaj 10 000 Paradimów.' },
  { code: 'PIGGYBANK', desc: 'Dodaj 1 000 Paradimów.' },
  { code: 'setmoney [kwota]', desc: 'Ustaw dokładną kwotę pieniędzy. Przykład: setmoney 500000' },
  { code: 'reliefallneeds', desc: 'Natychmiast wypełnij wszystkie potrzeby wybranej postaci.' },
  { code: 'setskilllevel [umiejętność] [poziom]', desc: 'Ustaw poziom umiejętności. Przykład: setskilllevel Cooking 10' },
  { code: 'getpregnant [1-3]', desc: 'Spraw, aby wybrana postać zaszła w ciążę.' },
  { code: 'givebirth', desc: 'Natychmiastowy poród.' },
  { code: 'editcharacter', desc: 'Otwórz ponownie kreatora postaci.' },
  { code: 'unstuck', desc: 'Napraw zablokowaną postać.' },
  { code: 'save', desc: 'Zapisz grę.' },
  { code: 'help', desc: 'Pokaż wszystkie dostępne polecenia.' },
];

const faqs = [
  { q: 'Jak otworzyć konsolę oszustw w Paralives?', a: 'Naciśnij Ctrl + F1 lub Ctrl + Shift + C na Windows. Na Mac spróbuj Ctrl + Fn + F1. Następnie wpisz dowolny kod oszustwa.' },
  { q: 'Czy kody oszustw w Paralives są wrażliwe na wielkość liter?', a: 'Nie. Kody oszustw w Paralives nie są wrażliwe na wielkość liter. Możesz wpisać "JACKPOT" lub "jackpot" — oba działają tak samo.' },
  { q: 'Jak dodać pieniądze w Paralives?', a: 'Użyj kodu "JACKPOT" aby dodać 50 000 Paradimów, "MAKEITRAIN" dla 10 000, lub "setmoney [kwota]" aby ustawić dokładną kwotę.' },
  { q: 'Jak wypełnić wszystkie potrzeby?', a: 'Wpisz "reliefallneeds" aby natychmiast wypełnić wszystkie potrzeby wybranej postaci.' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": { "@type": "Answer", "text": faq.a }
  }))
};
---

<Layout
  title="Paralives Kody"
  fullTitle="Paralives Kody 2026 - Wszystkie Kody Oszustw | Paralives Cheats"
  description="Wszystkie kody oszustw Paralives: pieniądze, potrzeby, umiejętności, ciąża i więcej. Kliknij, aby skopiować i użyć w konsoli."
  canonicalPath="/paralives-kody"
  schema={[faqSchema]}
  lang="pl"
>
  <Breadcrumb items={[
    { name: 'Home', href: '/' },
    { name: 'Paralives Kody' }
  ]} />

  <header class="max-w-7xl mx-auto px-6 py-16 md:py-24 text-center">
    <p class="text-sm font-bold text-gray-400 mb-4 uppercase tracking-wider">Zaktualizowano: Czerwiec 2026</p>
    <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight leading-[1.1] mb-6">
      <span class="bg-[#6366f1] text-white px-3 py-1 border border-black inline-block rotate-[-1deg]">Paralives Kody</span> Oszustw
    </h1>
    <p class="text-xl text-gray-700 max-w-2xl mx-auto leading-relaxed font-medium mb-6">
      Kompletna kolekcja kodów oszustw Paralives na rok 2026. Kliknij dowolny kod, aby go skopiować i wkleić do konsoli.
    </p>
    <p class="text-lg text-gray-500 font-bold">
      Naciśnij <span class="bg-[#FFD54F] px-2 border-2 border-black">Ctrl + F1</span> aby otworzyć konsolę.
    </p>
  </header>

  <section class="py-16 bg-white border-y-[3px] border-black">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl font-extrabold mb-8">Popularne Kody Oszustw</h2>
      <div class="space-y-3">
        {cheats.map(cheat => (
          <div class="flex items-center justify-between gap-4 bg-[#F9FAFB] border border-black rounded-2xl p-4 md:p-5 brutal-shadow">
            <div class="flex-1 min-w-0">
              <code class="bg-[#6366f1] text-white px-3 py-1 rounded-full text-sm font-bold border border-black">{cheat.code}</code>
              <span class="ml-3 text-gray-700 font-medium">{cheat.desc}</span>
            </div>
          </div>
        ))}
      </div>
      <div class="mt-8 text-center">
        <a href="/#cheats" class="brutal-btn bg-[#6366f1] text-white font-extrabold text-lg py-3 px-8 rounded-full border border-black brutal-shadow inline-flex items-center gap-2">
          Zobacz Wszystkie Kody →
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 bg-[#F9FAFB] border-b-[3px] border-black">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl font-extrabold mb-8 text-center">Często Zadawane Pytania</h2>
      <div class="space-y-4">
        {faqs.map(faq => (
          <div class="border border-black rounded-2xl p-6 bg-white brutal-shadow">
            <h3 class="text-xl font-extrabold mb-2">{faq.q}</h3>
            <p class="text-gray-700 font-medium text-lg">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-[#E0F2FE] border-b-[3px] border-black">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-extrabold mb-4">Więcej Paralives Cheats</h2>
      <p class="text-gray-600 font-medium text-lg mb-8">Szukasz więcej kodów? Odwiedź naszą główną stronę ze wszystkimi kodami.</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="/money-cheats" class="bg-white border border-black rounded-2xl p-6 brutal-shadow hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all block">
          <h3 class="font-extrabold text-lg mb-1">Money Cheats</h3>
          <p class="text-gray-600 font-medium">Kody na pieniądze</p>
        </a>
        <a href="/needs-cheats" class="bg-white border border-black rounded-2xl p-6 brutal-shadow hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all block">
          <h3 class="font-extrabold text-lg mb-1">Needs Cheats</h3>
          <p class="text-gray-600 font-medium">Kody na potrzeby</p>
        </a>
        <a href="/cheat-codes" class="bg-white border border-black rounded-2xl p-6 brutal-shadow hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all block">
          <h3 class="font-extrabold text-lg mb-1">All Cheat Codes</h3>
          <p class="text-gray-600 font-medium">Wszystkie kody</p>
        </a>
      </div>
    </div>
  </section>
</Layout>
