---
import Layout from '../layouts/Layout.astro';

const faqs = [
  { q: 'How do I open the cheat console in Paralives?', a: 'Press Ctrl + Shift + C on Windows or Cmd + Shift + C on Mac to open the cheat console. Type your cheat code and press Enter to activate it.' },
  { q: 'Are cheats available during early access?', a: 'Yes, many cheats are available during the early access period. The developers have confirmed that more cheat codes will be added as the game continues development.' },
  { q: 'Will using cheats disable achievements?', a: 'No, Paralives allows you to use cheats without disabling achievements or any game features. Feel free to experiment!' },
  { q: 'Can I use cheats on console?', a: 'Currently Paralives is only available on PC and Mac. There are no announced plans for console versions yet.' },
  { q: 'How do I get unlimited money?', a: 'Open the cheat console and type "money.infinite" to enable infinite money mode, or use "money.add 100000" to add a specific amount.' },
  { q: 'Can I build without restrictions?', a: 'Yes! Use the "build.freerealestate" cheat to place objects anywhere, and "build.ignoreobjects" to overlap objects freely.' },
  { q: 'How do I max out a skill instantly?', a: 'Open the console and type "skill.max [skillname]" where skillname is the skill you want to max. For example: "skill.max cooking".' },
  { q: 'Can I change my Para\'s age?', a: 'Yes, use "age.set [stage]" to set your Para to any age stage: baby, child, teen, adult, or elder. You can also use "age.up" or "age.down" to move one stage at a time.' },
  { q: 'How do I improve relationships quickly?', a: 'Use "rel.max [charactername]" to max out your relationship with any character. You can also use "rel.makefriend" or "rel.makeromantic" for instant relationship changes.' },
  { q: 'Do cheats work in build mode?', a: 'Yes! Many cheats are specifically for build mode. Use "build.moveobjects" for free placement, "build.unlockall" for all items, and "build.resize" to change object sizes.' },
  { q: 'How do I reset my Para\'s needs?', a: 'Use "needs.fill" to fill all needs for your current Para, or "needs.fillall" for everyone in the household. Use "needs.disable" to freeze needs so they never decrease.' },
  { q: 'Can I undo cheat effects?', a: 'Most cheats can be reversed by using the opposite command. For example, "money.remove" to take away money, or "needs.enable" to re-enable need decay after using "needs.disable".' },
  { q: 'Are there cheats for unlocking all items?', a: 'Yes, use "build.unlockall" in build mode to unlock all available items, including those normally locked behind gameplay progression.' },
  { q: 'How do I use the resize cheat?', a: 'Type "build.resize [number]" where the number is the scale factor. For example, "build.resize 2" makes an object twice as large, and "build.resize 0.5" makes it half size.' },
  { q: 'Will more cheats be added in future updates?', a: 'Yes, the developers have stated they plan to expand the cheat system as the game develops. Check back regularly for updated cheat lists.' },
];
---

<Layout title="FAQ" description="Frequently asked questions about Paralives cheats, console commands, and gameplay.">
  <section class="max-w-4xl mx-auto px-4 py-16">
    <h1 class="text-4xl font-bold text-center mb-4">Frequently Asked Questions</h1>
    <p class="text-center text-[#94a3b8] mb-12 max-w-2xl mx-auto">
      Everything you need to know about using cheats and console commands in Paralives.
    </p>

    <div class="space-y-4">
      {faqs.map(faq => (
        <details class="bg-[#1e293b] border border-[#334155] rounded-lg overflow-hidden group">
          <summary class="px-6 py-4 cursor-pointer font-semibold hover:bg-[#334155] transition-colors flex justify-between items-center">
            <span>{faq.q}</span>
            <span class="text-[#94a3b8] group-open:rotate-180 transition-transform ml-4">▼</span>
          </summary>
          <div class="px-6 py-4 border-t border-[#334155] text-[#94a3b8] leading-relaxed">
            {faq.a}
          </div>
        </details>
      ))}
    </div>
  </section>
</Layout>
