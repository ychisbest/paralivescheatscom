---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us">
  <section class="max-w-2xl mx-auto px-6 py-20">
    <h1 class="text-5xl font-extrabold tracking-tight text-center mb-4">Contact Us</h1>
    <p class="text-center text-gray-600 font-bold text-lg mb-12">
      Have questions, suggestions, or found an error? We'd love to hear from you.
    </p>

    <div class="bg-white border-[3px] border-black rounded-3xl p-8 brutal-shadow">
      <form class="space-y-6">
        <div>
          <label for="name" class="block font-extrabold text-lg mb-2">Name</label>
          <input type="text" id="name" name="name" class="w-full bg-[#F9FAFB] border-[3px] border-black rounded-xl px-4 py-3 font-medium focus:border-[#6366f1] focus:outline-none" placeholder="Your name" />
        </div>
        <div>
          <label for="email" class="block font-extrabold text-lg mb-2">Email</label>
          <input type="email" id="email" name="email" class="w-full bg-[#F9FAFB] border-[3px] border-black rounded-xl px-4 py-3 font-medium focus:border-[#6366f1] focus:outline-none" placeholder="your@email.com" />
        </div>
        <div>
          <label for="subject" class="block font-extrabold text-lg mb-2">Subject</label>
          <select id="subject" name="subject" class="w-full bg-[#F9FAFB] border-[3px] border-black rounded-xl px-4 py-3 font-medium focus:border-[#6366f1] focus:outline-none">
            <option>General Question</option>
            <option>Report an Error</option>
            <option>Suggest a Cheat</option>
            <option>DMCA Request</option>
            <option>Other</option>
          </select>
        </div>
        <div>
          <label for="message" class="block font-extrabold text-lg mb-2">Message</label>
          <textarea id="message" name="message" rows="5" class="w-full bg-[#F9FAFB] border-[3px] border-black rounded-xl px-4 py-3 font-medium focus:border-[#6366f1] focus:outline-none" placeholder="Your message..."></textarea>
        </div>
        <button type="submit" class="brutal-btn w-full bg-[#6366f1] text-white font-extrabold text-xl py-4 rounded-full border-[3px] border-black brutal-shadow hover:bg-[#4f46e5]">
          Send Message
        </button>
      </form>
    </div>
  </section>
</Layout>
