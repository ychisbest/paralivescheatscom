---
import Layout from '../layouts/Layout.astro';
import heroImg from '../images/hero.png';

const moneyCheats = [
  { code: 'PIGGYBANK', desc: 'Add 1,000 Paradimes to your household funds.' },
  { code: 'MAKEITRAIN', desc: 'Add 10,000 Paradimes to your household funds.' },
  { code: 'JACKPOT', desc: 'Add 50,000 Paradimes to your household funds.' },
  { code: 'LOTTERY', desc: 'Receive a random amount between 1 and 100,000 Paradimes.' },
  { code: 'setmoney [amount]', desc: 'Set household funds to an exact amount. Example: setmoney 500000' },
  { code: 'printmoney [amount]', desc: 'Add a specified amount without replacing your balance. Example: printmoney 20000' },
  { code: 'PAYDAY', desc: 'Receive the salary amount of the currently selected Para.' },
];

const needsCheats = [
  { code: 'reliefallneeds', desc: 'Instantly fill all needs for the selected Para.' },
  { code: 'reliefallneedsofallcharacters', desc: 'Restore all needs for every Para in the household.' },
  { code: 'reliefneed [NeedID]', desc: 'Fully restore one specific need. Example: reliefneed Hunger' },
  { code: 'setneed [NeedID] [1-10]', desc: 'Set a specific need to a value. Example: setneed Sleep 10' },
  { code: 'decayneed [NeedID] [amount]', desc: 'Reduce a need by a value. Example: decayneed Hygiene 2' },
  { code: 'showneeds', desc: 'Display all current need values for the selected Para.' },
];

const skillCheats = [
  { code: 'setskilllevel [skill] [level]', desc: 'Set a specific skill to a given level. Example: setskilllevel Cooking 10' },
  { code: 'levelupskill [skill]', desc: 'Add one level to a skill. Example: levelupskill Programming' },
  { code: 'showskills', desc: 'Show all current skill levels for the selected Para.' },
  { code: 'leveluppersonality', desc: 'Level up the personality traits of the selected Para.' },
];

const careerCheats = [
  { code: 'clearalloccupations', desc: 'Remove all occupation assignments from the selected Para.' },
  { code: 'endworkday', desc: 'Immediately end the current work day and collect salary.' },
  { code: 'clearstrikes', desc: 'Remove all work strikes from the selected Para.' },
  { code: 'upgradeoccupations', desc: 'Unlock occupation upgrades for the selected Para.' },
  { code: 'addvacationday', desc: 'Add a vacation day to the selected Para.' },
  { code: 'unenrollfromalloccupations', desc: 'Quit all current jobs for the selected Para.' },
];

const characterCheats = [
  { code: 'editcharacter', desc: 'Return to the character creator to edit the selected household.' },
  { code: 'setage [number]', desc: 'Set the selected Para\'s age. Example: setage 32' },
  { code: 'printage', desc: 'Print the selected Para\'s current age.' },
  { code: 'showpersonalitytraits', desc: 'Show personality-related values for the selected Para.' },
  { code: 'resetpersonality', desc: 'Reset personality to level 1.' },
  { code: 'showstatuseffects', desc: 'Display current status effects on the selected Para.' },
  { code: 'clearstatuseffects', desc: 'Clear all status effects from the selected Para.' },
  { code: 'gainstorycard', desc: 'Add a story card to the selected Para.' },
];

const pregnancyCheats = [
  { code: 'getpregnant [1-3]', desc: 'Make the selected Para pregnant. Optionally specify multiples. Example: getpregnant 2' },
  { code: 'givebirth', desc: 'Make the selected pregnant Para give birth immediately.' },
  { code: 'makebabies', desc: 'Make two selected Paras have a baby together.' },
  { code: 'pregnantstatus', desc: 'Show pregnancy progress and status.' },
];

const agingCheats = [
  { code: 'nextlifestage', desc: 'Advance the selected Para to the next life stage.' },
  { code: 'previouslifestage', desc: 'Revert the selected Para to the previous life stage.' },
  { code: 'nextgrowthspurt', desc: 'Trigger a growth spurt for infant or teen Paras.' },
  { code: 'previousgrowthspurt', desc: 'Revert a growth spurt for infant or teen Paras.' },
  { code: 'killcharacter', desc: 'Kill the selected Para. Warning: can cause game-over in single-person households.' },
  { code: 'reviveallselectedcharacters', desc: 'Revive all selected Paras.' },
];

const householdCheats = [
  { code: 'addselectedcharacterstohousehold', desc: 'Add selected NPC Paras to your current household.' },
  { code: 'createcharacter [name]', desc: 'Create a Para from a model GUID or display name. Example: createcharacter HumanAdult' },
  { code: 'kickselectedcharactersfromhousehold', desc: 'Remove selected Paras from the household.' },
  { code: 'showcharacterrelationships', desc: 'Show the selected Para\'s relationships and labels.' },
  { code: 'becomeacquaintancewitheveryone', desc: 'Add acquaintance relationship with all Paras in town.' },
];

const timeCheats = [
  { code: 'sethour [hour]', desc: 'Set the in-game time to a specific hour. Example: sethour 12' },
  { code: 'advanceday', desc: 'Advance time by 24 hours.' },
  { code: 'advancehour', desc: 'Advance time by one hour.' },
  { code: 'skipto5minutesbeforework', desc: 'Set time to five minutes before the selected Para\'s work starts.' },
];

const itemCheats = [
  { code: 'additemtoinventory [ItemID]', desc: 'Add a specified item to the selected Para\'s inventory.' },
  { code: 'printinventory', desc: 'Show item IDs for the selected Para\'s inventory.' },
  { code: 'clearinventory', desc: 'Remove all items from the selected Para\'s inventory.' },
  { code: 'repairallitems', desc: 'Repair all broken objects in the game.' },
  { code: 'unspoilallitems', desc: 'Make all spoiled food fresh again.' },
  { code: 'showiteminfos', desc: 'Show item ID for the selected Build Mode object.' },
];

const utilityCheats = [
  { code: 'completecurrentwants', desc: 'Instantly complete all current wants/goals for the selected Para.' },
  { code: 'clearwantcooldowns', desc: 'Allow new wants to appear from emotions.' },
  { code: 'extinguishallfires', desc: 'Extinguish all fires on the lot.' },
  { code: 'unstuck', desc: 'Fix the selected Para\'s location and pathing.' },
  { code: 'unstuckall', desc: 'Fix pathing for all Parafolks in the world.' },
  { code: 'save', desc: 'Save the current game.' },
  { code: 'zipsavefile', desc: 'Create a zipped backup of the current save file.' },
];

const debugCheats = [
  { code: 'fps', desc: 'Show the current frames per second.' },
  { code: 'capfps [number]', desc: 'Cap the frame rate. Example: capfps 60' },
  { code: 'benchmarkfps', desc: 'Start a 15-second FPS benchmark.' },
  { code: 'fullscreen', desc: 'Switch to fullscreen mode.' },
  { code: 'windowed', desc: 'Switch to windowed mode.' },
  { code: 'showcharacterposition', desc: 'Show the selected Para\'s coordinates and lot data.' },
  { code: 'warpcharacter [x,y,z]', desc: 'Teleport the selected Para to specific coordinates.' },
  { code: 'countitems', desc: 'Count all items in the world.' },
];

const easterEggCheats = [
  { code: 'BEAR', desc: 'Display bear ASCII art in the console.' },
  { code: 'CAT', desc: 'Display a black cat image in the console.' },
  { code: 'EIGHTBALL', desc: 'Show a random Magic 8 Ball-style phrase.' },
  { code: 'SPIN [chance]', desc: 'Spin a chance wheel. Example: spin 15%' },
  { code: 'RAGEQUIT', desc: 'Instantly exit the game.' },
];

const sections = [
  { id: 'money', title: 'Money & Bills', icon: '💰', color: 'bg-[#22c55e]', cheats: moneyCheats, desc: 'Use these Paralives cheats to get unlimited Paradimes and manage household bills.' },
  { id: 'needs', title: 'Needs & Wants', icon: '🔋', color: 'bg-[#f59e0b]', cheats: needsCheats, desc: 'Paralives cheats for instantly filling hunger, sleep, hygiene, and all other needs.' },
  { id: 'skills', title: 'Skills', icon: '⭐', color: 'bg-[#a855f7]', cheats: skillCheats, desc: 'Max out any skill instantly with these Paralives cheats for cooking, programming, and more.' },
  { id: 'career', title: 'Career & Occupation', icon: '💼', color: 'bg-[#ec4899]', cheats: careerCheats, desc: 'Advance your career using Paralives cheats for jobs, promotions, and vacation days.' },
  { id: 'character', title: 'Character Editing', icon: '🧑', color: 'bg-[#6366f1]', cheats: characterCheats, desc: 'Edit your Para with character Paralives cheats for age, personality, and appearance.' },
  { id: 'pregnancy', title: 'Pregnancy & Babies', icon: '👶', color: 'bg-[#f472b6]', cheats: pregnancyCheats, desc: 'Control pregnancy and babies with these Paralives cheats for instant birth and more.' },
  { id: 'aging', title: 'Aging & Life Stages', icon: '⏳', color: 'bg-[#78716c]', cheats: agingCheats, desc: 'Manage aging and life stages with Paralives cheats for growth spurts and revival.' },
  { id: 'household', title: 'Household & Relationships', icon: '🏠', color: 'bg-[#14b8a6]', cheats: householdCheats, desc: 'Build your household using Paralives cheats for relationships and NPC management.' },
  { id: 'time', title: 'Time Control', icon: '🕐', color: 'bg-[#8b5cf6]', cheats: timeCheats, desc: 'Control the in-game clock with these Paralives cheats for time manipulation.' },
  { id: 'items', title: 'Items & Inventory', icon: '🎒', color: 'bg-[#f97316]', cheats: itemCheats, desc: 'Manage your inventory with Paralives cheats for adding items and repairing objects.' },
  { id: 'utility', title: 'Utility & Save', icon: '🔧', color: 'bg-[#3b82f6]', cheats: utilityCheats, desc: 'Essential Paralives cheats for saving, fixing stuck Paras, and managing fires.' },
  { id: 'debug', title: 'UI & Performance', icon: '🖥️', color: 'bg-[#64748b]', cheats: debugCheats, desc: 'Debug Paralives cheats for FPS, teleportation, and performance monitoring.' },
  { id: 'easter', title: 'Fun & Easter Eggs', icon: '🎮', color: 'bg-[#e11d48]', cheats: easterEggCheats, desc: 'Fun Paralives cheats and Easter eggs for entertainment and surprises.' },
];

const faqs = [
  { q: 'How do I open the cheat console in Paralives?', a: 'Press Ctrl + F1 or Ctrl + Shift + C on Windows to open the cheat console. On Mac, try Ctrl + Fn + F1. Once open, type "help" or "cheatlist" to see all available Paralives cheats and commands.' },
  { q: 'Are Paralives cheats case-sensitive?', a: 'No. Paralives cheats are not case-sensitive. You also don\'t need a leading slash or any special "enable cheats" command — just open the console and start typing any Paralives cheat.' },
  { q: 'What are the money cheats in Paralives?', a: 'The most popular Paralives cheats for money are PIGGYBANK (+1,000), MAKEITRAIN (+10,000), JACKPOT (+50,000), or LOTTERY (random up to 100,000). "setmoney [amount]" sets an exact balance, "printmoney [amount]" adds to your current balance, and PAYDAY gives your Para\'s salary. These Paralives cheats are the fastest way to get rich.' },
  { q: 'How do I fill all needs instantly?', a: 'Type the Paralives cheat "reliefallneeds" to restore all needs for the selected Para. Use "reliefallneedsofallcharacters" for the entire household. For a single need, try "reliefneed Hunger" or "setneed Sleep 10". These Paralives cheats save tons of gameplay time.' },
  { q: 'How do I set a skill to a specific level?', a: 'Use the Paralives cheat "setskilllevel [skill] [level]" — for example, "setskilllevel Cooking 10". Use "showskills" first to see available skill IDs. You can also use "levelupskill [skill]" to add one level at a time with Paralives cheats.' },
  { q: 'Can I control pregnancy with Paralives cheats?', a: 'Yes. Use the Paralives cheat "getpregnant" to make a Para pregnant (add a number 1-3 for multiples), "givebirth" for instant delivery, "makebabies" for two selected Paras, and "pregnantstatus" to check progress.' },
  { q: 'How do I age up or change life stages?', a: 'Use the Paralives cheat "nextlifestage" to advance to the next life stage or "previouslifestage" to go back. For infants and teens, "nextgrowthspurt" and "previousgrowthspurt" control growth spurts specifically. These Paralives cheats give full control over aging.' },
  { q: 'Can I bring a dead Para back to life?', a: 'Yes — use the Paralives cheat "reviveallselectedcharacters" to revive selected Paras. Be careful with "killcharacter" as it can cause game-over in single-person households. Always save before using destructive Paralives cheats.' },
  { q: 'How do I fix a stuck Para?', a: 'Type the Paralives cheat "unstuck" to fix the selected Para\'s pathing. If multiple Paras are stuck, use "unstuckall" to fix everyone in the world at once. This is one of the most useful Paralives cheats for bug fixes.' },
  { q: 'What time control Paralives cheats are available?', a: 'Use "sethour [number]" to jump to a specific hour, "advanceday" to skip 24 hours, "advancehour" to skip one hour, or "skipto5minutesbeforework" to jump right before your Para\'s shift. These Paralives cheats are great for time management.' },
  { q: 'How do I manage fires?', a: 'Use the Paralives cheat "extinguishallfires" to put out all fires on the lot. You can also set things on fire with "setitemonfire" or "setselectedcharactersonfire" — just save first before using these Paralives cheats.' },
  { q: 'Will using Paralives cheats disable achievements?', a: 'Paralives allows cheats without disabling achievements or features. You can use Paralives cheats freely without worrying about losing progress or locked content.' },
  { q: 'Are Paralives cheats stable in Early Access?', a: 'Paralives is in Early Access (2026), so Paralives cheats may change, be renamed, or break after patches. Always type "help" to check your current version\'s available Paralives cheats, and save before experimenting.' },
  { q: 'What are the Easter egg Paralives cheats?', a: 'Fun Paralives cheats include BEAR (ASCII art), CAT (cat image), EIGHTBALL (Magic 8 Ball), and SPIN [chance] (spin a wheel). RAGEQUIT instantly exits the game. These hidden Paralives cheats add fun surprises.' },
  { q: 'How do I back up my save?', a: 'Use the Paralives cheat "save" to save, then "zipsavefile" to create a zipped backup (reportedly saved to your desktop). Do this before testing any destructive Paralives cheats or debug commands.' },
  { q: 'What need IDs can I use with Paralives cheats?', a: 'Reported need IDs for Paralives cheats include: Affection, Bathroom, Fun, Grump, Hunger, Hygiene, Peace, Sleep, MeTime, EnergySurplus, GetAwayFromFire, and NeedToMove. Use "showneeds" to see current values for your Paralives cheats.' },
  { q: 'Does Paralives support mods?', a: 'Paralives supports user-created content through Steam Workshop. Players can share houses, custom content, and Parafolks. Script mods are not currently planned, but Paralives cheats cover most needs.' },
];

const latestGuides = [
  { title: 'Building Tips & Tricks', description: 'Master the build mode with tips on grid placement, terrain tools, and creative layouts. Combine these tips with our Paralives cheats for the best experience.', href: '/building-tips' },
  { title: 'Gameplay Guides', description: 'From creating your first Para to mastering careers and relationships. Pair these guides with Paralives cheats for maximum fun.', href: '/gameplay-guides' },
];
---

<Layout title="Home">
  <!-- Hero Section -->
  <header class="max-w-7xl mx-auto px-6 py-20 md:py-32 text-center">
    <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight leading-[1.1] mb-8">
      All <span class="bg-[#6366f1] text-white px-3 py-1 border-[3px] border-black inline-block rotate-[-1deg]">Paralives</span> Cheats<br>
      <span class="text-gray-600">in One Place.</span>
    </h1>
    <p class="text-xl md:text-2xl text-gray-700 max-w-2xl mx-auto leading-relaxed font-medium mb-4">
      The most complete collection of Paralives cheats for the 2026 Early Access release. Click to copy any cheat code, paste it into the console, and enjoy. All Paralives cheats are tested and ready to use.
    </p>
    <p class="text-lg text-gray-500 font-bold mb-10 max-w-2xl mx-auto">
      Press <span class="bg-[#FFD54F] px-2 border-2 border-black">Ctrl + F1</span> or <span class="bg-[#FFD54F] px-2 border-2 border-black">Ctrl + Shift + C</span> to open the console. Type <span class="bg-[#FFD54F] px-2 border-2 border-black">help</span> for all commands.
    </p>
    <a href="#cheats" class="brutal-btn bg-[#6366f1] text-white font-extrabold text-xl py-4 px-10 rounded-full border-[3px] border-black brutal-shadow inline-flex items-center gap-2">
      Browse All Cheats
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
    </a>
    <div class="mt-12 max-w-4xl mx-auto">
      <img src={heroImg.src} alt="Paralives gameplay" class="w-full rounded-3xl border-[3px] border-black brutal-shadow" />
    </div>
  </header>

  <!-- Stats Bar -->
  <section class="bg-black text-white py-10 border-y-[3px] border-black">
    <p class="text-center text-gray-400 font-bold mb-6 text-sm tracking-wider uppercase">The most comprehensive Paralives cheats database online</p>
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-2 md:grid-cols-6 gap-8 text-center divide-x-2 divide-gray-700">
      <div><div class="text-3xl md:text-4xl font-extrabold text-[#FFD54F]">76+</div><div class="mt-1 font-bold text-gray-300 text-sm">Total Cheats</div></div>
      <div><div class="text-3xl md:text-4xl font-extrabold text-[#22c55e]">13</div><div class="mt-1 font-bold text-gray-300 text-sm">Categories</div></div>
      <div><div class="text-3xl md:text-4xl font-extrabold text-[#a855f7]">4</div><div class="mt-1 font-bold text-gray-300 text-sm">Skill Codes</div></div>
      <div><div class="text-3xl md:text-4xl font-extrabold text-[#f472b6]">4</div><div class="mt-1 font-bold text-gray-300 text-sm">Pregnancy</div></div>
      <div><div class="text-3xl md:text-4xl font-extrabold text-[#14b8a6]">5</div><div class="mt-1 font-bold text-gray-300 text-sm">Household</div></div>
      <div><div class="text-3xl md:text-4xl font-extrabold text-[#e11d48]">5</div><div class="mt-1 font-bold text-gray-300 text-sm">Easter Eggs</div></div>
    </div>
  </section>

  <!-- All Cheats -->
  <section id="cheats" class="py-24 bg-white border-b-[3px] border-black">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-4xl md:text-5xl font-extrabold mb-4 text-center">
        All Paralives <span class="bg-[#FFD54F] px-2 border-2 border-black inline-block">Cheat Codes</span>
      </h2>
      <p class="text-center text-gray-600 font-medium text-lg max-w-2xl mx-auto mb-8">
        Browse every Paralives cheat code below. These Paralives cheats cover money, needs, skills, careers, pregnancy, and more. Click any cheat to copy it instantly.
      </p>

      <!-- Category Navigation -->
      <nav class="flex flex-wrap justify-center gap-2 mb-16 max-w-4xl mx-auto">
        {sections.map(section => (
          <a href={`#${section.id}`} class={`${section.color} text-white text-sm font-bold px-3 py-1.5 rounded-full border-[2px] border-black hover:opacity-80 transition-opacity`}>
            {section.icon} {section.title}
          </a>
        ))}
      </nav>

      <div class="space-y-16">
        {sections.map(section => (
          <div id={section.id}>
            <h3 class="text-2xl font-extrabold mb-2 flex items-center gap-3">
              <span class={`w-12 h-12 ${section.color} border-[3px] border-black rounded-2xl flex items-center justify-center brutal-shadow text-xl`}>{section.icon}</span>
              {section.title}
            </h3>
            <p class="text-gray-600 font-medium mb-6 ml-15">{section.desc}</p>
            <div class="space-y-3">
              {section.cheats.map(cheat => (
                <div class="flex items-center justify-between gap-4 bg-[#F9FAFB] border-[3px] border-black rounded-2xl p-4 md:p-5 hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all brutal-shadow">
                  <div class="flex-1 min-w-0">
                    <code class={`${section.color} text-white px-3 py-1 rounded-full text-sm font-bold border-[2px] border-black`}>{cheat.code}</code>
                    <span class="ml-3 text-gray-700 font-medium">{cheat.desc}</span>
                  </div>
                  <button
                    class="copy-btn flex-shrink-0 w-10 h-10 bg-white border-[3px] border-black rounded-full flex items-center justify-center hover:bg-[#FFD54F] transition-colors brutal-shadow"
                    data-code={cheat.code.replace(/\s*\[.*?\]/g, '').trim()}
                    title="Copy to clipboard"
                  >
                    <svg class="copy-icon h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                      <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
                      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
                    </svg>
                    <svg class="check-icon h-5 w-5 hidden text-[#22c55e]" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                  </button>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- Quick Reference -->
      <div class="mt-16 bg-[#E0F2FE] border-[3px] border-black rounded-3xl p-8 brutal-shadow">
        <h3 class="text-2xl font-extrabold mb-2">Quick Reference: Most Used Paralives Cheats</h3>
        <p class="text-gray-600 font-medium mb-4">These are the Paralives cheats every player should know. Copy any code below and paste it into the console.</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-gray-800 font-medium">
          <div><code class="bg-black text-white px-2 py-0.5 rounded-full text-sm font-bold">setmoney 50000</code> — Set exact money</div>
          <div><code class="bg-black text-white px-2 py-0.5 rounded-full text-sm font-bold">jackpot</code> — Add 50,000 Paradimes</div>
          <div><code class="bg-black text-white px-2 py-0.5 rounded-full text-sm font-bold">reliefallneeds</code> — Fill all needs</div>
          <div><code class="bg-black text-white px-2 py-0.5 rounded-full text-sm font-bold">setskilllevel Cooking 10</code> — Max a skill</div>
          <div><code class="bg-black text-white px-2 py-0.5 rounded-full text-sm font-bold">advanceday</code> — Skip 24 hours</div>
          <div><code class="bg-black text-white px-2 py-0.5 rounded-full text-sm font-bold">unstuck</code> — Fix stuck Para</div>
          <div><code class="bg-black text-white px-2 py-0.5 rounded-full text-sm font-bold">editcharacter</code> — Reopen creator</div>
          <div><code class="bg-black text-white px-2 py-0.5 rounded-full text-sm font-bold">save</code> — Save game</div>
          <div><code class="bg-black text-white px-2 py-0.5 rounded-full text-sm font-bold">zipsavefile</code> — Backup save</div>
          <div><code class="bg-black text-white px-2 py-0.5 rounded-full text-sm font-bold">help</code> — Show all commands</div>
        </div>
      </div>

      <div class="mt-8 bg-[#FFD54F] border-[3px] border-black rounded-3xl p-8 brutal-shadow">
        <h3 class="text-2xl font-extrabold mb-4">Tips for Using Paralives Cheats</h3>
        <ul class="space-y-3 text-gray-800 font-medium">
          <li class="flex items-start gap-3">
            <span class="text-xl">⚠️</span>
            <span>Paralives is in Early Access (2026). These Paralives cheats may change with updates. Type <code class="bg-black text-white px-2 py-0.5 rounded-full text-sm font-bold">help</code> in the console for the latest list of available Paralives cheats.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-xl">💾</span>
            <span>Always save before using destructive Paralives cheats like <code class="bg-black text-white px-2 py-0.5 rounded-full text-sm font-bold">killcharacter</code>, <code class="bg-black text-white px-2 py-0.5 rounded-full text-sm font-bold">spawnallitems</code>, or <code class="bg-black text-white px-2 py-0.5 rounded-full text-sm font-bold">toggleedittown</code>. Use <code class="bg-black text-white px-2 py-0.5 rounded-full text-sm font-bold">zipsavefile</code> for a backup.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-xl">💡</span>
            <span>When using Paralives cheats for money, age, needs, or skills, start with moderate values. Very large numbers may cause UI overflow or save problems.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-xl">🔄</span>
            <span>Click a Paralives cheat's confirmation message in the console to quickly repeat it without retyping.</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Guides -->
