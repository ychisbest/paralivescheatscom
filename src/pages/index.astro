---
import Layout from '../layouts/Layout.astro';
import heroImg from '../images/hero.png';

const moneyCheats = [
  { code: 'SETMONEY', desc: 'Change household balance to a specified amount. Example: SETMONEY 20000' },
  { code: 'PRINTMONEY', desc: 'Add Paradimes to your funds. Example: PRINTMONEY 20000' },
  { code: 'PAYDAY', desc: 'Receive the salary of the selected Para.' },
  { code: 'PIGGYBANK', desc: 'Add 1,000 Paradimes.' },
  { code: 'MAKEITRAIN', desc: 'Add 10,000 Paradimes.' },
  { code: 'JACKPOT', desc: 'Add 50,000 Paradimes.' },
  { code: 'LOTTERY', desc: 'Receive a random amount between 1 and 100,000 Paradimes.' },
  { code: 'GENERATEBILL', desc: 'Send an updated bank statement to the mailbox.' },
  { code: 'CLEARBILLS', desc: 'Clear all bills in the mailbox.' },
  { code: 'CLEARSELECTEDCHARACTERSBILLS', desc: 'Clear all bills for the selected Para.' },
  { code: 'TOGGLEOGMONEYCHANGES', desc: 'Log money changes in the console.' },
  { code: 'CAUSEOUTAGE', desc: 'Cut power to the selected lot.' },
  { code: 'FIXOUTAGE', desc: 'Fix power outage on the selected lot.' },
];

const timeCheats = [
  { code: 'SETTIMESCALE', desc: 'Set game time speed (default is 1). Example: SETTIMESCALE 2' },
  { code: 'PAUSETIME', desc: 'Pause or resume game time.' },
  { code: 'SETTIME', desc: 'Set in-game time. Example: SETTIME 14:30' },
  { code: 'SETDAY', desc: 'Set the day of the week. Example: SETDAY Friday' },
  { code: 'ADVANCEDAYS', desc: 'Advance a specified number of days. Example: ADVANCEDAYS 3' },
  { code: 'SEASON', desc: 'Change the season. Example: SEASON Summer' },
];

const characterCheats = [
  { code: 'LEVELUPSKILL', desc: 'Raise a skill for the selected Para. Example: LEVELUPSKILL Piano' },
  { code: 'SETSKILLLEVEL', desc: 'Set a skill to a specific level. Example: SETSKILLLEVEL Cooking 10' },
  { code: 'PRINTAGE', desc: 'Display the selected Para\'s age.' },
  { code: 'RESETPERSONALITY', desc: 'Reset personality to level 1, remove traits and upgrades.' },
  { code: 'SHOWCHARACTERRELATIONSHIPS', desc: 'Show all relationships and relationship labels.' },
  { code: 'COMPLETECURRENTWANTS', desc: 'Auto-complete all current wants for the selected Para.' },
  { code: 'LEARNALLRECIPES', desc: 'Learn all recipes.' },
  { code: 'LEARNALLSKINS', desc: 'Learn all skin/appearance options.' },
  { code: 'OPENPARAMAKER', desc: 'Open the Paramaker character editor.' },
  { code: 'GETEQUIPMENT', desc: 'Show all options chosen when creating this character.' },
  { code: 'GETSEX', desc: 'Display the selected Para\'s gender.' },
  { code: 'SHOWCURRENTCHARACTERGUID', desc: 'Show the selected character\'s GUID (unique identifier).' },
];

const needsCheats = [
  { code: 'FILLALLNEEDS', desc: 'Fill all needs to max.' },
  { code: 'FILLNEED', desc: 'Fill a specific need. Example: FILLNEED Hunger' },
  { code: 'DRAINNEED', desc: 'Drain a specific need. Example: DRAINNEED Energy' },
  { code: 'SETNEED', desc: 'Set a specific need to a value. Example: SETNEED Hygiene 50' },
  { code: 'ENABLENEEDDECAY', desc: 'Enable or disable need decay. Example: ENABLENEEDDECAY false' },
  { code: 'FREEZENEEDS', desc: 'Freeze all needs (no more decay).' },
];

const pregnancyCheats = [
  { code: 'GETPREGNANT', desc: 'Make the selected Para pregnant (specify 1-3 babies). Example: GETPREGNANT 1' },
  { code: 'GIVEBIRTH', desc: 'Selected Para gives birth immediately (no pregnancy required).' },
];

const agingCheats = [
  { code: 'SETAGE', desc: 'Set the selected Para\'s age. Example: SETAGE 35' },
  { code: 'NEWLIFESTAGE', desc: 'Age the Para to the next life stage.' },
  { code: 'PREVIOUSLIFESTAGE', desc: 'Revert the Para to the previous life stage.' },
  { code: 'NEXTGROWTHSPURT', desc: 'Move the Para to the next growth spurt if applicable.' },
  { code: 'KILL', desc: 'Kill the selected Para.' },
  { code: 'REVIVE', desc: 'Revive the selected Para.' },
  { code: 'DISABLEAGING', desc: 'Disable or enable aging. Example: DISABLEAGING true' },
];

const careerCheats = [
  { code: 'GETJOB', desc: 'Get a specified job. Example: GETJOB Cooking' },
  { code: 'QUITJOB', desc: 'Quit the current job.' },
  { code: 'PROMOTE', desc: 'Promote the current job.' },
  { code: 'DEMOTE', desc: 'Demote the current job.' },
  { code: 'SETJOBLEVEL', desc: 'Set the job level. Example: SETJOBLEVEL 5' },
];

const buildCheats = [
  { code: 'REPAIRALLITEMS', desc: 'Repair all items (remove broken state).' },
  { code: 'UNSPOILALLITEMS', desc: 'Remove all spoiled state from food.' },
  { code: 'SETITEMSTATE', desc: 'Change the state of the selected item. Example: SETITEMSTATE IsOn 1' },
  { code: 'SHOWITEMSTATES', desc: 'Show animation and interaction data for the selected item.' },
  { code: 'ADDITEMTOINVENTORY', desc: 'Add an item to the Para\'s inventory by ID. Example: ADDITEMTOINVENTORY ClutterClothingRingEngagement' },
  { code: 'SHOWITEMINFOS', desc: 'Show item ID for the selected Build Mode object.' },
  { code: 'PRINTINVENTORY', desc: 'Show all item IDs in the Para\'s inventory.' },
  { code: 'CLEARINVENTORY', desc: 'Remove all items from the Para\'s inventory.' },
  { code: 'SPAWNALLITEMS', desc: 'Spawn every item on the lot (may crash the game!).' },
  { code: 'UNLOCKALLITEMS', desc: 'Unlock all items.' },
];

const fireCheats = [
  { code: 'EXTINGUISHALLFIRES', desc: 'Extinguish all active fires.' },
  { code: 'EXTINGUISHSELECTEDCHARACTERSONFIRE', desc: 'Extinguish fire on the selected Para.' },
  { code: 'SETITEMONFIRE', desc: 'Set the selected item on fire.' },
  { code: 'SETSELECTEDCHARACTERSONFIRE', desc: 'Set the selected Para on fire.' },
];

const mailCheats = [
  { code: 'GENERATEBILL', desc: 'Send an updated bank statement to the mailbox.' },
  { code: 'CLEARBILLS', desc: 'Clear all bills in the mailbox.' },
  { code: 'RESETMUSEUMDONATIONS', desc: 'Clear all museum donations.' },
];

const debugCheats = [
  { code: 'ALIASES', desc: 'List all aliases.' },
  { code: 'CLEAR', desc: 'Clear the cheat command box.' },
  { code: 'HELP', desc: 'Show all cheat codes.' },
  { code: 'SCHEDULE', desc: 'Schedule a command to run every frame, output in top-left. Example: SCHEDULE FPS' },
  { code: 'STOP', desc: 'Stop a previously scheduled cheat command.' },
  { code: 'UNSTUCK', desc: 'Move the selected Para to the correct navmesh position.' },
  { code: 'UNSTUCKALL', desc: 'Move all Paras to correct navmesh positions.' },
  { code: 'CANCELALLCHARACTERSINTERACTIONS', desc: 'Cancel all queued interactions in the entire town.' },
  { code: 'CANCELALLHOUSEHOLDINTERACTIONS', desc: 'Cancel all queued interactions in the household.' },
  { code: 'SHOWCURRENTSOCIALGROUPCONVERSATION', desc: 'Show current social group conversation in the console.' },
  { code: 'SHOWSOCIALGROUPSCLUSTERS', desc: 'Show all current social group clusters in the console.' },
  { code: 'DELETEALLSOCIALGROUPS', desc: 'End any current social groups.' },
  { code: 'SHOWMANAGERLISTSCOUNT', desc: 'Show manager lists for the current lot in the console.' },
  { code: 'VIEWMEMORYLOG', desc: 'Show a specific Para\'s memory log in the console.' },
];

const performanceCheats = [
  { code: 'FPS', desc: 'Show frame rate.' },
  { code: 'VSYNC', desc: 'Enable or disable VSync. Example: VSYNC false' },
  { code: 'RESOLUTION', desc: 'Set resolution. Example: RESOLUTION 1920x1080' },
  { code: 'WINDOWED', desc: 'Toggle windowed mode. Example: WINDOWED true' },
  { code: 'QUALITY', desc: 'Set graphics quality. Example: QUALITY High' },
];

const easterEggCheats = [
  { code: 'BEAR', desc: 'Create bear ASCII art.' },
  { code: 'CAT', desc: 'Display a cat.' },
  { code: 'EIGHTBALL', desc: 'Give a random Magic 8 Ball result.' },
  { code: 'HOTEL', desc: 'Display "Trivago" in the console.' },
  { code: 'RAGEQUIT', desc: 'Close the game.' },
];

const sections = [
  { id: 'money', title: 'Money & Bills', icon: '💰', color: 'bg-[#22c55e]', cheats: moneyCheats, desc: 'Use these Paralives cheats to get unlimited Paradimes and manage household bills.' },
  { id: 'time', title: 'Time Control', icon: '🕐', color: 'bg-[#8b5cf6]', cheats: timeCheats, desc: 'Control the in-game clock with these Paralives cheats for time manipulation.' },
  { id: 'character', title: 'Character Attributes', icon: '🧑', color: 'bg-[#6366f1]', cheats: characterCheats, desc: 'Edit your Para with character Paralives cheats for skills, personality, and appearance.' },
  { id: 'needs', title: 'Needs & Wants', icon: '🔋', color: 'bg-[#f59e0b]', cheats: needsCheats, desc: 'Paralives cheats for instantly filling hunger, sleep, hygiene, and all other needs.' },
  { id: 'pregnancy', title: 'Pregnancy & Babies', icon: '👶', color: 'bg-[#f472b6]', cheats: pregnancyCheats, desc: 'Control pregnancy and babies with these Paralives cheats for instant birth and more.' },
  { id: 'aging', title: 'Aging & Death', icon: '⏳', color: 'bg-[#78716c]', cheats: agingCheats, desc: 'Manage aging, life stages, death and revival with these Paralives cheats.' },
  { id: 'career', title: 'Career & Occupation', icon: '💼', color: 'bg-[#ec4899]', cheats: careerCheats, desc: 'Advance your career using Paralives cheats for jobs, promotions, and job levels.' },
  { id: 'build', title: 'Build Mode', icon: '🔨', color: 'bg-[#f97316]', cheats: buildCheats, desc: 'Manage items, inventory, and build mode objects with these Paralives cheats.' },
  { id: 'fire', title: 'Fire', icon: '🔥', color: 'bg-[#ef4444]', cheats: fireCheats, desc: 'Start or extinguish fires with these Paralives cheats.' },
  { id: 'mail', title: 'Mail & Bills', icon: '📮', color: 'bg-[#14b8a6]', cheats: mailCheats, desc: 'Manage bills and museum donations with these Paralives cheats.' },
  { id: 'debug', title: 'Debug & Miscellaneous', icon: '🖥️', color: 'bg-[#64748b]', cheats: debugCheats, desc: 'Debug Paralives cheats for stuck Paras, social groups, and memory logs.' },
  { id: 'performance', title: 'Performance', icon: '📊', color: 'bg-[#3b82f6]', cheats: performanceCheats, desc: 'Performance Paralives cheats for FPS, resolution, and graphics quality.' },
  { id: 'easter', title: 'Fun & Easter Eggs', icon: '🎮', color: 'bg-[#e11d48]', cheats: easterEggCheats, desc: 'Fun Paralives cheats and Easter eggs for entertainment and surprises.' },
];

const faqs = [
  { q: 'How do I open the cheat console in Paralives?', a: 'Press Ctrl + Shift + C or Ctrl + F1 on Windows. On macOS, press Command + Fn/Globe + F1. The console appears minimized in the top-right corner — click the circle icon to expand it.' },
  { q: 'Are Paralives cheats case-sensitive?', a: 'No. Paralives cheats are not case-sensitive. You also don\'t need a leading slash or any special "enable cheats" command — just open the console and start typing any Paralives cheat.' },
  { q: 'What are the money cheats in Paralives?', a: 'The most popular Paralives cheats for money are PIGGYBANK (+1,000), MAKEITRAIN (+10,000), JACKPOT (+50,000), or LOTTERY (random up to 100,000). "SETMONEY [amount]" sets an exact balance, "PRINTMONEY [amount]" adds to your current balance, and PAYDAY gives your Para\'s salary. These Paralives cheats are the fastest way to get rich.' },
  { q: 'How do I fill all needs instantly?', a: 'Type the Paralives cheat "FILLALLNEEDS" to restore all needs for the selected Para. For a single need, try "FILLNEED Hunger" or "SETNEED Hygiene 50". Use "FREEZENEEDS" to stop all need decay entirely. These Paralives cheats save tons of gameplay time.' },
  { q: 'How do I set a skill to a specific level?', a: 'Use the Paralives cheat "SETSKILLLEVEL [skill] [level]" — for example, "SETSKILLLEVEL Cooking 10". You can also use "LEVELUPSKILL [skill]" to add one level at a time with Paralives cheats.' },
  { q: 'Can I control pregnancy with Paralives cheats?', a: 'Yes. Use the Paralives cheat "GETPREGNANT" to make a Para pregnant (add a number 1-3 for multiples), and "GIVEBIRTH" for instant delivery.' },
  { q: 'How do I age up or change life stages?', a: 'Use the Paralives cheat "NEWLIFESTAGE" to advance to the next life stage or "PREVIOUSLIFESTAGE" to go back. "NEXTGROWTHSPURT" controls growth spurts for infants and teens. Use "DISABLEAGING true" to stop aging entirely. These Paralives cheats give full control over aging.' },
  { q: 'Can I bring a dead Para back to life?', a: 'Yes — use the Paralives cheat "REVIVE" to revive the selected Para. Be careful with "KILL" as it can cause game-over in single-person households. Always save before using destructive Paralives cheats.' },
  { q: 'How do I fix a stuck Para?', a: 'Type the Paralives cheat "UNSTUCK" to fix the selected Para\'s pathing. If multiple Paras are stuck, use "UNSTUCKALL" to fix everyone in the world at once. This is one of the most useful Paralives cheats for bug fixes.' },
  { q: 'What time control Paralives cheats are available?', a: 'Use "SETTIME [time]" to jump to a specific time (e.g. SETTIME 14:30), "SETDAY [day]" to change the day, "ADVANCEDAYS [number]" to skip days, "SEASON [name]" to change the season, or "PAUSETIME" to freeze time. "SETTIMESCALE [number]" adjusts game speed. These Paralives cheats are great for time management.' },
  { q: 'How do I manage fires?', a: 'Use the Paralives cheat "EXTINGUISHALLFIRES" to put out all fires. You can also set things on fire with "SETITEMONFIRE" or "SETSELECTEDCHARACTERSONFIRE" — just save first before using these Paralives cheats.' },
  { q: 'Will using Paralives cheats disable achievements?', a: 'Paralives allows cheats without disabling achievements or features. You can use Paralives cheats freely without worrying about losing progress or locked content.' },
  { q: 'Are Paralives cheats stable in Early Access?', a: 'Paralives is in Early Access (2026), so Paralives cheats may change, be renamed, or break after patches. Always type "HELP" to check your current version\'s available Paralives cheats, and save before experimenting.' },
  { q: 'What are the Easter egg Paralives cheats?', a: 'Fun Paralives cheats include BEAR (ASCII art), CAT (cat image), EIGHTBALL (Magic 8 Ball), and HOTEL (displays "Trivago"). RAGEQUIT instantly exits the game. These hidden Paralives cheats add fun surprises.' },
  { q: 'How do I control need decay?', a: 'Use "ENABLENEEDDECAY false" to disable need decay entirely, or "FREEZENEEDS" to freeze all needs at their current values. Use "ENABLENEEDDECAY true" to re-enable decay. These Paralives cheats let you play without worrying about needs.' },
  { q: 'How do I manage my career with Paralives cheats?', a: 'Use "GETJOB [field]" to get a job (e.g. GETJOB Cooking), "QUITJOB" to quit, "PROMOTE" to advance, "DEMOTE" to downgrade, and "SETJOBLEVEL [number]" to set your job level directly. These Paralives cheats give full control over careers.' },
  { q: 'Does Paralives support mods?', a: 'Paralives supports user-created content through Steam Workshop. Players can share houses, custom content, and Parafolks. Script mods are not currently planned, but Paralives cheats cover most needs.' },
];

const latestGuides = [
  { title: 'Building Tips & Tricks', description: 'Master the build mode with tips on grid placement, terrain tools, and creative layouts. Combine these tips with our Paralives cheats for the best experience.', href: '/building-tips' },
  { title: 'Gameplay Guides', description: 'From creating your first Para to mastering careers and relationships. Pair these guides with Paralives cheats for maximum fun.', href: '/gameplay-guides' },
];

const webSiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Paralives Cheats",
  "url": "https://paralives-cheats.com",
  "description": "The most complete collection of Paralives cheats for the 2026 Early Access release.",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://paralives-cheats.com/?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
};
---

<Layout
  title="Home"
  fullTitle="Paralives Cheats 2026 - All 92+ Cheat Codes (Money, Skills, Pregnancy, Build Mode) | Paralives Cheats"
  description="The most complete collection of Paralives cheats for the 2026 Early Access. Browse 92+ cheat codes for money, needs, skills, careers, pregnancy, build mode, and more. Click to copy and use instantly."
  canonicalPath="/"
  schema={[webSiteSchema, faqSchema]}
>
  <!-- Hero Section -->
  <header class="max-w-7xl mx-auto px-6 py-20 md:py-32 text-center">
    <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight leading-[1.1] mb-8">
      All <span class="bg-[#6366f1] text-white px-3 py-1 border border-black inline-block rotate-[-1deg]">Paralives</span> Cheats<br>
      <span class="text-gray-600">in One Place.</span>
    </h1>
    <p class="text-sm font-bold text-gray-400 mb-4 uppercase tracking-wider">Updated: June 2026</p>
    <p class="text-xl md:text-2xl text-gray-700 max-w-2xl mx-auto leading-relaxed font-medium mb-4">
      The most complete collection of Paralives cheats for the 2026 Early Access release. 92+ cheat codes across 13 categories. Click to copy any cheat code, paste it into the console, and enjoy.
    </p>
    <p class="text-lg text-gray-500 font-bold mb-10 max-w-2xl mx-auto">
      Press <span class="bg-[#FFD54F] px-2 border-2 border-black">Ctrl + Shift + C</span> or <span class="bg-[#FFD54F] px-2 border-2 border-black">Ctrl + F1</span> to open the console. Type <span class="bg-[#FFD54F] px-2 border-2 border-black">HELP</span> for all commands.
    </p>
    <a href="#cheats" class="brutal-btn bg-[#6366f1] text-white font-extrabold text-xl py-4 px-10 rounded-full border border-black brutal-shadow inline-flex items-center gap-2">
      Browse All Cheats
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
    </a>
    <div class="mt-12 max-w-4xl mx-auto">
      <img src={heroImg.src} alt="Paralives gameplay" class="w-full rounded-3xl border border-black brutal-shadow" />
    </div>
  </header>

  <!-- Stats Bar -->
  <section class="bg-black text-white py-10 border-y-[3px] border-black">
    <p class="text-center text-gray-400 font-bold mb-6 text-sm tracking-wider uppercase">The most comprehensive Paralives cheats database online</p>
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-2 md:grid-cols-6 gap-8 text-center divide-x-2 divide-gray-700">
      <div><div class="text-3xl md:text-4xl font-extrabold text-[#FFD54F]">92+</div><div class="mt-1 font-bold text-gray-300 text-sm">Total Cheats</div></div>
      <div><div class="text-3xl md:text-4xl font-extrabold text-[#22c55e]">13</div><div class="mt-1 font-bold text-gray-300 text-sm">Categories</div></div>
      <div><div class="text-3xl md:text-4xl font-extrabold text-[#a855f7]">12</div><div class="mt-1 font-bold text-gray-300 text-sm">Character</div></div>
      <div><div class="text-3xl md:text-4xl font-extrabold text-[#f97316]">10</div><div class="mt-1 font-bold text-gray-300 text-sm">Build Mode</div></div>
      <div><div class="text-3xl md:text-4xl font-extrabold text-[#14b8a6]">3</div><div class="mt-1 font-bold text-gray-300 text-sm">Mail</div></div>
      <div><div class="text-3xl md:text-4xl font-extrabold text-[#e11d48]">5</div><div class="mt-1 font-bold text-gray-300 text-sm">Easter Eggs</div></div>
    </div>
  </section>

  <!-- All Cheats -->
  <section id="cheats" class="py-24 bg-white border-b-[3px] border-black">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-4xl md:text-5xl font-extrabold mb-4 text-center">
        All Paralives <span class="bg-[#FFD54F] px-2 border-2 border-black inline-block">Cheat Codes</span>
      </h2>
      <p class="text-center text-gray-600 font-medium text-lg max-w-2xl mx-auto mb-8">
        Browse every Paralives cheat code below. These Paralives cheats cover money, time, character attributes, needs, pregnancy, aging, career, build mode, fire, and more. Click any cheat to copy it instantly.
      </p>

      <!-- Category Navigation -->
      <nav class="flex flex-wrap justify-center gap-2 mb-16 max-w-4xl mx-auto opacity-70">
        {sections.map(section => (
          <a href={`#${section.id}`} class={`${section.color} text-white text-sm font-bold px-3 py-1.5 rounded-full border border-black hover:opacity-100 transition-opacity`}>
            {section.title}
          </a>
        ))}
      </nav>

      <div class="space-y-16">
        {sections.map(section => (
          <div id={section.id}>
            <h3 class="text-2xl font-extrabold mb-2">
              {section.title}
            </h3>
            <p class="text-gray-600 font-medium mb-6">{section.desc}</p>
            <div class="space-y-3">
              {section.cheats.map(cheat => (
                <div class="flex items-center justify-between gap-4 bg-[#F9FAFB] border border-black rounded-2xl p-4 md:p-5 hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all brutal-shadow">
                  <div class="flex-1 min-w-0">
                    <code class={`${section.color} text-white px-3 py-1 rounded-full text-sm font-bold border border-black`}>{cheat.code}</code>
                    <span class="ml-3 text-gray-700 font-medium">{cheat.desc}</span>
                  </div>
                  <button
                    class="copy-btn flex-shrink-0 w-10 h-10 bg-white border border-black rounded-full flex items-center justify-center hover:bg-[#FFD54F] transition-colors brutal-shadow"
                    data-code={cheat.code.replace(/\s*\[.*?\]/g, '').trim()}
                    title="Copy to clipboard"
                  >
                    <svg class="copy-icon h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                      <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
                      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
                    </svg>
                    <svg class="check-icon h-5 w-5 hidden text-[#22c55e]" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                  </button>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- Quick Reference -->
      <div class="mt-16 bg-[#E0F2FE] border border-black rounded-3xl p-8 brutal-shadow">
        <h3 class="text-2xl font-extrabold mb-2">Quick Reference: Most Used Paralives Cheats</h3>
        <p class="text-gray-600 font-medium mb-4">These are the Paralives cheats every player should know. Copy any code below and paste it into the console.</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-gray-800 font-medium">
          <div><code class="bg-black text-white px-2 py-0.5 rounded-full text-sm font-bold">SETMONEY 50000</code> — Set exact money</div>
          <div><code class="bg-black text-white px-2 py-0.5 rounded-full text-sm font-bold">JACKPOT</code> — Add 50,000 Paradimes</div>
          <div><code class="bg-black text-white px-2 py-0.5 rounded-full text-sm font-bold">FILLALLNEEDS</code> — Fill all needs</div>
          <div><code class="bg-black text-white px-2 py-0.5 rounded-full text-sm font-bold">SETSKILLLEVEL Cooking 10</code> — Max a skill</div>
          <div><code class="bg-black text-white px-2 py-0.5 rounded-full text-sm font-bold">ADVANCEDAYS 1</code> — Skip a day</div>
