---
import Layout from '../layouts/Layout.astro';
import CheatTable from '../components/CheatTable.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const cheats = [
  { code: 'SETSKILLLEVEL', desc: 'Set a specific skill to a given level. Example: SETSKILLLEVEL Cooking 10' },
  { code: 'LEVELUPSKILL', desc: 'Add one level to a skill. Example: LEVELUPSKILL Piano' },
];

const faqs = [
  { q: 'How do I max out a skill in Paralives?', a: 'Use "SETSKILLLEVEL [skill] 10" to instantly max a skill to level 10. For example, "SETSKILLLEVEL Cooking 10" maxes out the Cooking skill.' },
  { q: 'What skill IDs are available in Paralives?', a: 'Common skill IDs include: Cooking, Programming, Painting, Writing, Music, Gardening, Athletic, Charisma, Logic, Piano, and more.' },
  { q: 'How do I add one skill level at a time?', a: 'Use "LEVELUPSKILL [skill]" to add one level. For example, "LEVELUPSKILL Piano" raises Piano skill by one level.' },
  { q: 'Can I level up personality traits?', a: 'Personality traits can be managed with RESETPERSONALITY (reset to level 1) and other character attribute cheats. See the full character cheats list for more.' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": { "@type": "Answer", "text": faq.a }
  }))
};

const relatedPages = [
  { title: 'Career Cheats', href: '/#career', desc: 'Advance your career' },
  { title: 'Money Cheats', href: '/money-cheats', desc: 'Get unlimited Paradimes' },
  { title: 'Needs Cheats', href: '/needs-cheats', desc: 'Fill all needs instantly' },
  { title: 'All Cheats', href: '/#cheats', desc: 'Browse all 92+ cheats' },
];
---

<Layout
  title="Skill Cheats"
  fullTitle="Paralives Skill Cheats 2026 - SETSKILLLEVEL & All Skill Codes | Paralives Cheats"
  description="All Paralives skill cheats: SETSKILLLEVEL, LEVELUPSKILL. Max out any skill instantly with these tested cheat codes."
  canonicalPath="/skill-cheats"
  schema={[faqSchema]}
>
  <Breadcrumb items={[
    { name: 'Home', href: '/' },
    { name: 'Skill Cheats' }
  ]} />

  <header class="max-w-7xl mx-auto px-6 py-16 md:py-24 text-center">
    <p class="text-sm font-bold text-gray-400 mb-4 uppercase tracking-wider">Updated: June 2026</p>
    <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight leading-[1.1] mb-6">
      Paralives <span class="bg-[#a855f7] text-white px-3 py-1 border border-black inline-block rotate-[-1deg]">Skill Cheats</span>
    </h1>
    <p class="text-xl text-gray-700 max-w-2xl mx-auto leading-relaxed font-medium mb-6">
      Max out any skill instantly with Paralives skill cheats. Use SETSKILLLEVEL and LEVELUPSKILL to master cooking, programming, piano, and every other skill.
    </p>
    <p class="text-lg text-gray-500 font-bold">
      Press <span class="bg-[#FFD54F] px-2 border-2 border-black">Ctrl + F1</span> to open the console, then type any code below.
    </p>
  </header>

  <section class="py-16 bg-white border-y-[3px] border-black">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl font-extrabold mb-2">All Skill Cheat Codes</h2>
      <p class="text-gray-600 font-medium mb-8">Click any code to copy it to your clipboard, then paste into the console.</p>
      <CheatTable cheats={cheats} color="bg-[#a855f7]" />

      <div class="mt-12 bg-[#F3E8FF] border border-black rounded-3xl p-8 brutal-shadow">
        <h3 class="text-2xl font-extrabold mb-4">⭐ Skill Cheat Tips</h3>
        <ul class="space-y-3 text-gray-800 font-medium">
          <li class="flex items-start gap-3">
            <span class="text-xl">📊</span>
            <span><code class="bg-black text-white px-2 py-0.5 rounded-full text-sm font-bold">SETSKILLLEVEL Cooking 10</code> sets Cooking to max level 10 instantly.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-xl">📈</span>
            <span>Use <code class="bg-black text-white px-2 py-0.5 rounded-full text-sm font-bold">LEVELUPSKILL</code> to add one level at a time — great for gradual progression.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-xl">🧠</span>
            <span>Personality traits can be reset with <code class="bg-black text-white px-2 py-0.5 rounded-full text-sm font-bold">RESETPERSONALITY</code> — see character cheats for more.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-xl">💡</span>
            <span>Common skill IDs: Cooking, Programming, Painting, Writing, Music, Gardening, Athletic, Charisma, Logic, Piano.</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section class="py-16 bg-[#F9FAFB] border-b-[3px] border-black">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl font-extrabold mb-8 text-center">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqs.map(faq => (
          <div class="border border-black rounded-2xl p-6 bg-white brutal-shadow">
            <h3 class="text-xl font-extrabold mb-2">{faq.q}</h3>
            <p class="text-gray-700 font-medium text-lg">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-[#E0F2FE] border-b-[3px] border-black">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl font-extrabold mb-8 text-center">Related Paralives Cheats</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {relatedPages.map(page => (
          <a href={page.href} class="bg-white border border-black rounded-2xl p-6 brutal-shadow hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all block">
            <h3 class="font-extrabold text-lg mb-1">{page.title}</h3>
            <p class="text-gray-600 font-medium">{page.desc}</p>
            <span class="font-bold text-[#6366f1] underline underline-offset-4 decoration-2 text-sm">View Cheats →</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const code = btn.getAttribute('data-code');
      if (!code) return;
      try {
        await navigator.clipboard.writeText(code);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = code;
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
      }
      const copyIcon = btn.querySelector('.copy-icon');
      const checkIcon = btn.querySelector('.check-icon');
      copyIcon.classList.add('hidden');
      checkIcon.classList.remove('hidden');
      setTimeout(() => {
        copyIcon.classList.remove('hidden');
        checkIcon.classList.add('hidden');
      }, 1500);
    });
  });
</script>
