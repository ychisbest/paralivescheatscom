---
import Layout from '../layouts/Layout.astro';

const guides = [
  {
    title: 'Getting Started with Paralives',
    content: 'New to Paralives? Start by creating your first Para using the detailed character creator (the Paramaker), then build a basic home. Learn how needs work — keep your Para fed, rested, and happy. Use "reliefallneeds" to fill all needs instantly, or "setneed Hunger 10" for a specific one. The game supports color wheels, height sliders, body sculpting, and layered clothing right from day one of Early Access.',
    color: 'bg-[#6366f1]',
  },
  {
    title: 'Creating the Perfect Para',
    content: 'The Paramaker offers deep customization: color wheel, height slider, body and face sliders, tattoo placement, layered clothing, asymmetry options, and a genetics system. Use "editcharacter" to return to the creator at any time. Personality traits affect behavior — use "showpersonalitytraits" to inspect them, "leveluppersonality" to boost, or "resetpersonality" to start over.',
    color: 'bg-[#ec4899]',
  },
  {
    title: 'Career Guide: Jobs & Promotions',
    content: 'Each career has its own promotion track and upgrade paths. Use "printalloccupations" to see all jobs held by a Para, and "upgradeoccupations" to unlock upgrades. If your Para gets strikes, use "clearstrikes" to reset them. "endworkday" skips a shift and grants salary. "addvacationday" adds time off. To quit everything: "unenrollfromalloccupations".',
    color: 'bg-[#f59e0b]',
  },
  {
    title: 'Relationship System Explained',
    content: 'Build friendships, romances, and rivalries through social interactions and shared activities. Use "showcharacterrelationships" to inspect all relationships and labels. "becomeacquaintancewitheveryone" adds an acquaintance label with every Para in town. "completecurrentwants" fast-tracks relationship goals, and "clearwantcooldowns" lets new wants appear from emotions.',
    color: 'bg-[#22c55e]',
  },
  {
    title: 'Skill Guide: How to Level Up',
    content: 'Skills include Music, Piano, Guitar, Fitness, Dancing, Science, Astronomy, Biology, Technology, Programming, GraphicDesign, Cooking, Painting, Repair, Language, and more. Use "showskills" to see current levels, "setskilllevel Cooking 10" to set a level, or "levelupskill Programming" to add one. Some skills may not work in the current Early Access build — verify with "showskills".',
    color: 'bg-[#a855f7]',
  },
  {
    title: 'Money Making Guide',
    content: 'Careers pay salaries — use PAYDAY to collect on demand. For quick cash: PIGGYBANK (+1,000), MAKEITRAIN (+10,000), JACKPOT (+50,000), or LOTTERY (random up to 100,000) Paradimes. "setmoney 100000" sets an exact balance, "printmoney 20000" adds to your current amount. Use "generatebill" to check bills, "clearbills" to clear them, and "printhouseholdfunds" to see every household\'s balance.',
    color: 'bg-[#22c55e]',
  },
  {
    title: 'Pregnancy, Babies & Family',
    content: 'Start a family with "getpregnant" (add 1-3 for multiples), "givebirth" for instant delivery, or "makebabies" for two selected Paras. Check progress with "pregnantstatus". Control aging with "nextlifestage" and "previouslifestage", or trigger growth spurts with "nextgrowthspurt". If tragedy strikes, "reviveallselectedcharacters" brings Paras back. Use money cheats to set up each generation with the resources they need.',
    color: 'bg-[#f472b6]',
  },
  {
    title: 'Household & NPC Management',
    content: 'Manage your household with "addselectedcharacterstohousehold" to recruit NPCs, "createcharacter HumanAdult" to spawn new Paras, or "kickselectedcharactersfromhousehold" to remove members. Use "showcharacterposition" to find a Para\'s coordinates, "warpcharacter x,y,z" to teleport them, and "unstuck" or "unstuckall" to fix pathing issues.',
    color: 'bg-[#14b8a6]',
  },
  {
    title: 'Time Control & Events',
    content: 'Control the clock with "sethour 12" to jump to noon, "advanceday" to skip 24 hours, or "advancehour" for smaller jumps. "skipto5minutesbeforework" is perfect for getting Para to their job on time. Manage emergencies with "extinguishallfires" and handle mail with "generatemail" or "resetmailbox".',
    color: 'bg-[#8b5cf6]',
  },
  {
    title: 'Performance & Debugging',
    content: 'Monitor performance with "fps" and "benchmarkfps". Cap your framerate with "capfps 60". Switch display modes with "fullscreen" or "windowed". Fix issues with "unstuck" for pathing, "cleanupduplicateditems" for duplicate objects, and "repairallitems" for broken objects. Use "save" and "zipsavefile" before experimenting with debug commands.',
    color: 'bg-[#64748b]',
  },
];
---

<Layout title="Gameplay Guides" description="Complete Paralives gameplay guides covering careers, relationships, skills, money cheats, and more. Updated for 2026 Early Access.">
  <section class="max-w-4xl mx-auto px-6 py-20">
    <h1 class="text-5xl md:text-6xl font-extrabold tracking-tight text-center mb-4">
      Gameplay <span class="bg-[#a855f7] text-white px-3 border border-black inline-block rotate-[1deg]">Guides</span>
    </h1>
    <p class="text-center text-gray-600 font-bold text-lg mb-16 max-w-2xl mx-auto">
      Comprehensive guides to master every aspect of Paralives. Includes cheat tips for each topic.
    </p>

    <div class="space-y-8">
      {guides.map(guide => (
        <article class="bg-white border border-black rounded-3xl p-8 brutal-shadow hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all">
          <div class="flex items-start gap-4 mb-4">
            <span class={`${guide.color} w-4 h-4 rounded-full border border-black flex-shrink-0 mt-1`}></span>
            <h2 class="text-2xl font-extrabold">{guide.title}</h2>
          </div>
          <p class="text-gray-700 font-medium text-lg leading-relaxed ml-0 md:ml-8">{guide.content}</p>
        </article>
      ))}
    </div>
  </section>
</Layout>
