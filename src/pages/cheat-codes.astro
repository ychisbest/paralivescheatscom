---

<Layout
  title="Cheat Codes"
  fullTitle="Paralives Cheat Codes 2026 - Complete Quick Reference (92+ Codes) | Paralives Cheats"
  description="Complete list of all Paralives cheat codes in one table. 92+ codes for money, needs, skills, pregnancy, career, build mode, and more. Quick reference for the 2026 Early Access."
  canonicalPath="/cheat-codes"
  schema={[faqSchema]}
>
  <Breadcrumb items={[
    { name: 'Home', href: '/' },
    { name: 'Cheat Codes' }
  ]} />

  <header class="max-w-7xl mx-auto px-6 py-16 md:py-24 text-center">
    <p class="text-sm font-bold text-gray-400 mb-4 uppercase tracking-wider">Updated: June 2026</p>
    <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight leading-[1.1] mb-6">
      All Paralives <span class="bg-[#e11d48] text-white px-3 py-1 border border-black inline-block rotate-[-1deg]">Cheat Codes</span>
    </h1>
    <p class="text-xl text-gray-700 max-w-2xl mx-auto leading-relaxed font-medium">
      The complete quick reference list of all 92+ Paralives cheat codes. Find any cheat code fast.
    </p>
  </header>

  <section class="py-16 bg-white border-y-[3px] border-black">
    <div class="max-w-5xl mx-auto px-6">
      <div class="overflow-x-auto">
        <table class="w-full border border-black rounded-2xl overflow-hidden brutal-shadow">
          <thead class="bg-black text-white">
            <tr>
              <th class="p-3 text-left font-extrabold text-sm">Category</th>
              <th class="p-3 text-left font-extrabold text-sm">Code</th>
              <th class="p-3 text-left font-extrabold text-sm">Description</th>
            </tr>
          </thead>
          <tbody>
            {allCheats.map((cheat, i) => (
              <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#F9FAFB]'}>
                <td class="p-3 font-bold text-sm border-b border-gray-200">{cheat.category}</td>
                <td class="p-3 border-b border-gray-200">
                  <code class="bg-[#6366f1] text-white px-2 py-0.5 rounded-full text-xs font-bold">{cheat.code}</code>
                </td>
                <td class="p-3 text-gray-700 font-medium text-sm border-b border-gray-200">{cheat.desc}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="py-16 bg-[#F9FAFB] border-b-[3px] border-black">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl font-extrabold mb-8 text-center">Related Paralives Cheats</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {relatedPages.map(page => (
          <a href={page.href} class="bg-white border border-black rounded-2xl p-6 brutal-shadow hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all block">
            <h3 class="font-extrabold text-lg mb-1">{page.title}</h3>
            <p class="text-gray-600 font-medium">{page.desc}</p>
            <span class="font-bold text-[#6366f1] underline underline-offset-4 decoration-2 text-sm">View Cheats →</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
