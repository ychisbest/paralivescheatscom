  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
      <div>
        <h3 class="text-lg font-bold text-[#e2e8f0] mb-3">Paralives Cheats</h3>
        <p class="text-sm text-[#94a3b8]">
          Your ultimate resource for Paralives cheats, tips, building guides, and gameplay strategies.
