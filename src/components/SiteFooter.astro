        <h3 class="text-lg font-bold text-[#e2e8f0] mb-3">Quick Links</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/cheats" class="text-[#94a3b8] hover:text-[#6366f1]">Cheats</a></li>
          <li><a href="/building-tips" class="text-[#94a3b8] hover:text-[#6366f1]">Building Tips</a></li>
          <li><a href="/gameplay-guides" class="text-[#94a3b8] hover:text-[#6366f1]">Gameplay Guides</a></li>
