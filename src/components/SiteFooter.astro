---
const currentYear = new Date().getFullYear();
---

<footer class="bg-white pt-16 pb-8 border-t-[3px] border-black mt-16">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-8 h-8 bg-[#6366f1] rounded-full border border-black"></div>
          <span class="font-extrabold text-xl">Paralives Cheats</span>
        </div>
        <p class="font-medium text-gray-600">
          Your ultimate resource for Paralives cheats, tips, building guides, and gameplay strategies. All Paralives cheats are updated for the 2026 Early Access release.
        </p>
      </div>

      <div>
        <h4 class="font-extrabold text-lg mb-4">Quick Links</h4>
        <ul class="space-y-3 font-bold text-gray-600">
          <li><a href="/#cheats" class="hover:text-black hover:underline">All Cheats</a></li>
          <li><a href="/cheat-codes" class="hover:text-black hover:underline">Cheat Codes</a></li>
          <li><a href="/money-cheats" class="hover:text-black hover:underline">Money Cheats</a></li>
          <li><a href="/needs-cheats" class="hover:text-black hover:underline">Needs Cheats</a></li>
          <li><a href="/skill-cheats" class="hover:text-black hover:underline">Skill Cheats</a></li>
          <li><a href="/pregnancy-cheats" class="hover:text-black hover:underline">Pregnancy Cheats</a></li>
          <li><a href="/console-commands" class="hover:text-black hover:underline">Console Commands</a></li>
          <li><a href="/building-tips" class="hover:text-black hover:underline">Building Tips</a></li>
          <li><a href="/gameplay-guides" class="hover:text-black hover:underline">Gameplay Guides</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-extrabold text-lg mb-4">Legal</h4>
        <ul class="space-y-3 font-bold text-gray-600">
          <li><a href="/privacy-policy" class="hover:text-black hover:underline">Privacy Policy</a></li>
          <li><a href="/terms-of-service" class="hover:text-black hover:underline">Terms of Service</a></li>
          <li><a href="/cookie-policy" class="hover:text-black hover:underline">Cookie Policy</a></li>
          <li><a href="/dmca" class="hover:text-black hover:underline">DMCA</a></li>
          <li><a href="/contact" class="hover:text-black hover:underline">Contact</a></li>
          <li><a href="/links" class="hover:text-black hover:underline">Partner Links</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t-[3px] border-black pt-8 flex flex-col md:flex-row justify-between items-center gap-4 font-bold text-gray-500">
      <p>&copy; {currentYear} Paralives Cheats. All rights reserved.</p>
      <p>Not affiliated with the Paralives development team.</p>
    </div>
  </div>
</footer>
