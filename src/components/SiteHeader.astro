---
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/building-tips', label: 'Building Tips' },
  { href: '/gameplay-guides', label: 'Gameplay Guides' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-[#FCFCFD] border-b-[3px] border-black">
  <nav class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
    <a href="/" class="flex items-center gap-3">
      <div class="w-10 h-10 bg-[#6366f1] rounded-full border-[3px] border-black flex items-center justify-center brutal-shadow">
        <span class="text-white font-black text-sm">PC</span>
      </div>
      <span class="font-extrabold text-2xl tracking-tight">Paralives Cheats</span>
    </a>

    <ul class="hidden lg:flex items-center gap-8 font-bold text-lg">
      {navItems.map(item => (
        <li>
          <a
            href={item.href}
            class:list={[
              'transition-colors',
              currentPath === item.href
                ? 'text-[#6366f1]'
                : 'hover:text-[#6366f1]',
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-4">
      <a href="/#cheats" class="hidden md:block font-bold hover:underline underline-offset-4 decoration-2">Cheats</a>
      <a href="/#cheats" class="brutal-btn bg-[#FFD54F] text-black font-bold py-2.5 px-6 rounded-full border-[3px] border-black brutal-shadow inline-block">
        View Cheats
      </a>
    </div>

    <button id="mobile-menu-btn" class="lg:hidden font-bold">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>
  <div id="mobile-menu" class="hidden lg:hidden bg-[#FCFCFD] border-t-[3px] border-black px-6 py-4">
    <ul class="flex flex-col gap-4 font-bold text-lg">
      {navItems.map(item => (
        <li>
          <a
            href={item.href}
            class:list={[
              'block transition-colors',
              currentPath === item.href
                ? 'text-[#6366f1]'
                : 'hover:text-[#6366f1]',
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
      <li><a href="/#cheats" class="block hover:text-[#6366f1]">Cheats</a></li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
